---
import { getCollection } from 'astro:content';
import MaintenanceContent from '../../components/MaintenanceContent.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { siteSettings } from '../../config/site';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const rubriques = ['Articles', 'Veille', 'Technos'];
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, 'fr'),
);
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, siteSettings.siteUrl).toString();
const pageTitle = 'Blog | Le Singe Du Numérique';
const pageDescription =
  'Articles, veille et technos : des ressources utiles pour mieux comprendre le numérique, suivre des outils et découvrir des solutions concrètes.';
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${siteSettings.siteName} — Blog`,
  url: canonicalUrl,
  description: pageDescription,
  inLanguage: 'fr-FR',
};
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)}></script>
  </head>
  <body>
    {
      siteSettings.maintenanceMode ? (
        <MaintenanceContent />
      ) : (
        <>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>

    <header>
    <nav class="navbar" aria-label="Navigation du blog">
      <div class="container nav-container">
        <a href="/" class="brand-logo" aria-label="Le Singe Du Numérique, accueil">
          <img src="/logo.svg" alt="" aria-hidden="true" class="navbar-logo" />
          <span class="brand-text">Le Singe Du Numérique</span>
        </a>
        <div class="nav-right">
          <ul class="nav-links">
            <li><a href="/projets" class="nav-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a></li>
            <li><a href="/asso" class="nav-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a></li>
            <li><a href="/evenements" class="nav-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a></li>
            <li><a href="/adhesion" class="nav-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a></li>
            <li><a href="/contact" class="nav-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a></li>
            <li><a href="/blog" class="nav-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a></li>
          </ul>
          <button
            id="theme-toggle"
            class="theme-btn"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            <span class="icon-light">☀️</span>
            <span class="icon-dark">🌙</span>
          </button>
        </div>

        <button
          class="burger-btn"
          id="burger-btn"
          aria-label="Ouvrir le menu principal"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div
        class="mobile-menu"
        id="mobile-menu"
        aria-label="Navigation mobile"
        aria-hidden="true"
        inert
        hidden
      >
        <a href="/projets" class="mobile-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
        <a href="/asso" class="mobile-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a>
        <a href="/evenements" class="mobile-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
        <a href="/adhesion" class="mobile-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a>
        <a href="/contact" class="mobile-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a>
        <a href="/blog" class="mobile-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
        <div class="mobile-theme-toggle">
          <span>Changer le thème</span>
          <button
            id="mobile-theme-btn"
            class="theme-btn-small"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            🌙
          </button>
        </div>
      </div>
    </nav>
    </header>

    <main id="main-content">
      <section class="hero-section">
        <div class="glow-bg glow-green"></div>
        <div class="glow-bg glow-orange"></div>

        <div class="container hero-content">
          <p class="eyebrow">Blog</p>
          <h1 class="hero-title">
            Ressources, <span class="gradient-text">veille</span> et technos
          </h1>
          <p class="hero-desc">
            Articles pratiques, sélection de ressources utiles et contenus plus techniques pour mieux comprendre le numérique au quotidien.
          </p>

          <div class="hero-meta">
            <span id="results-count" aria-live="polite">{posts.length} article{posts.length > 1 ? 's' : ''}</span>
            <span>•</span>
            <span>{allTags.length} tag{allTags.length > 1 ? 's' : ''}</span>
          </div>

          <form class="search-panel" id="blog-filters" action="/blog" method="get">
            <label class="sr-only" for="blog-search">Recherche dans les articles du blog</label>
            <div class="search-bar">
              <span class="search-icon" aria-hidden="true">
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
              </span>
              <input
                id="blog-search"
                name="search"
                type="search"
                placeholder="Rechercher un article, un auteur ou un sujet..."
                class="search-input"
                autocomplete="off"
              />
              <button type="submit" class="search-button">Rechercher</button>
            </div>

            <div class="filters-row">
              <fieldset class="filter-group">
                <legend class="filter-label">Rubriques</legend>
                <div class="tag-cloud">
                  <button type="button" class="cloud-tag is-active" data-rubrique="">Toutes les rubriques</button>
                  {rubriques.map((rubrique) => (
                    <button type="button" class="cloud-tag" data-rubrique={rubrique}>{rubrique}</button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="filter-group">
                <legend class="filter-label">Tags</legend>
                <div class="tag-cloud">
                  <button type="button" class="cloud-tag is-active" data-tag="">Tous les tags</button>
                  {allTags.map((tag) => (
                    <button type="button" class="cloud-tag" data-tag={tag}>{tag}</button>
                  ))}
                </div>
              </fieldset>

              <a href="/blog" class="reset-link">Réinitialiser les filtres</a>
            </div>
          </form>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Derniers <span class="text-accent">articles</span></h2>
            <div class="line-deco"></div>
          </div>

          <p class="empty-state" id="empty-state" hidden aria-live="polite">Aucun article ne correspond à ce filtre pour le moment.</p>

          <div class="posts-grid" id="posts-grid">
            {posts.map((post, index) => {
              const searchable = [
                post.data.title,
                post.data.description,
                post.data.author ?? '',
                ...post.data.tags,
              ].join(' ');
              return (
                <article
                  class={`post-card ${index === 0 ? 'featured' : ''}`}
                  data-tags={post.data.tags.join('|')}
                  data-rubrique={post.data.rubrique}
                  data-searchable={searchable}
                >
                  <div class={`card-top ${index % 3 === 0 ? 'card-green' : index % 3 === 1 ? 'card-orange' : 'card-blue'}`}>
                    <span class="card-kicker">
                      {post.data.pubDate.toLocaleDateString('fr-FR', {
                        day: 'numeric',
                        month: 'short',
                        year: 'numeric',
                      })}
                    </span>
                  </div>

                  <div class="post-content">
                    <div class="rubrique-chip">{post.data.rubrique}</div>
                    <div class="tag-list">
                      {post.data.tags.map((tag) => (
                        <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
                      ))}
                    </div>

                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>

                    <a href={`/blog/${post.id}/`} class="post-link">
                      Lire l'article →
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    </main>

    <section class="content-section">
      <div class="container">
        <ShareButtons title="Ressources, veille et technos" label="Partager le blog" />
      </div>
    </section>

    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-main">
          <div class="footer-brand">
            <img src="/logo.svg" alt="" aria-hidden="true" class="footer-logo" />
            <span>Le Singe Du Numérique</span>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Menu</span>
            <ul class="footer-line-content footer-links">
              <li><a href="/projets">Projets</a></li>
              <li><a href="/asso">L’association</a></li>
              <li><a href="/evenements">Événements</a></li>
              <li><a href="/adhesion">Rejoindre</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/plan-du-site">Plan du site</a></li>
              <li><a href="/mentions-legales">Mentions légales</a></li>
            </ul>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Statut</span>
            <div class="footer-line-content">
              <a class="service-status" href="https://le-singe-du-numerique.betteruptime.com/" target="_blank" rel="noopener noreferrer">
                <span class="status-dot status-ok" aria-hidden="true"></span>
                <span>Statut des services</span>
              </a>
              <span class="footer-separator">•</span>
              <a href="/accessibilite">Accessibilité : non conforme</a>
            </div>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Crédit</span>
            <div class="footer-line-content">
              <span class="footer-credit">Fait avec ❤️ entre père et fils - Stan et Mikaël BOUCHET</span>
            </div>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Réseaux</span>
            <ul class="footer-line-content footer-socials">
              <li>
                <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                  <span>LinkedIn Stan</span>
                </a>
              </li>
              <li>
                <a href="https://www.linkedin.com/in/mikael-bch/" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                  <span>LinkedIn Mikaël</span>
                </a>
              </li>
              <li>
                <a href="https://github.com/Stan69000/lesingedunumerique" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.35-3.87-1.35-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.27 1.17-3.07-.12-.29-.5-1.47.11-3.05 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.13-1.17 3.13-1.17.62 1.58.24 2.76.12 3.05.73.8 1.17 1.82 1.17 3.07 0 4.41-2.69 5.37-5.25 5.66.41.36.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
                  <span>GitHub</span>
                </a>
              </li>
            </ul>
        </div>
      </div>
    </footer>

    <script>
      const params = new URLSearchParams(window.location.search);
      const normalize = (value) =>
        (value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();

      const searchInput = document.getElementById('blog-search');
      const rubriqueButtons = Array.from(document.querySelectorAll('[data-rubrique]'));
      const tagButtons = Array.from(document.querySelectorAll('[data-tag]'));
      const cards = Array.from(document.querySelectorAll('.post-card'));
      const countNode = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');

      let selectedRubrique = params.get('rubrique') || '';
      let selectedTag = params.get('tag') || '';

      if (searchInput) {
        searchInput.value = params.get('search') || '';
      }

      function syncRubriqueButtons() {
        const normalizedRubrique = normalize(selectedRubrique);
        rubriqueButtons.forEach((button) => {
          const isActive = normalize(button.dataset.rubrique || '') === normalizedRubrique;
          button.classList.toggle('is-active', isActive);
        });
      }

      function syncTagButtons() {
        const normalizedTag = normalize(selectedTag);
        tagButtons.forEach((button) => {
          const isActive = normalize(button.dataset.tag || '') === normalizedTag;
          button.classList.toggle('is-active', isActive);
        });
      }

      function updateUrl(searchTerm) {
        const nextParams = new URLSearchParams();
        if (searchTerm) nextParams.set('search', searchTerm);
        if (selectedRubrique) nextParams.set('rubrique', selectedRubrique);
        if (selectedTag) nextParams.set('tag', selectedTag);
        const nextQuery = nextParams.toString();
        const nextUrl = nextQuery ? `/blog?${nextQuery}` : '/blog';
        window.history.replaceState({}, '', nextUrl);
      }

      function applyFilters() {
        const searchTerm = normalize(searchInput?.value || '');
        const normalizedRubrique = normalize(selectedRubrique);
        const normalizedTag = normalize(selectedTag);
        let visibleCount = 0;

        cards.forEach((card) => {
          const searchable = normalize(card.dataset.searchable || '');
          const rubrique = normalize(card.dataset.rubrique || '');
          const tags = (card.dataset.tags || '').split('|').map(normalize);
          const matchesSearch = !searchTerm || searchable.includes(searchTerm);
          const matchesRubrique = !normalizedRubrique || rubrique === normalizedRubrique;
          const matchesTag = !normalizedTag || tags.includes(normalizedTag);
          const visible = matchesSearch && matchesRubrique && matchesTag;
          card.hidden = !visible;
          if (visible) visibleCount += 1;
        });

        if (countNode) {
          countNode.textContent = `${visibleCount} article${visibleCount > 1 ? 's' : ''}`;
        }

        if (emptyState) {
          emptyState.hidden = visibleCount !== 0;
        }

        syncRubriqueButtons();
        syncTagButtons();
        updateUrl(searchTerm);
      }

      rubriqueButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedRubrique = button.dataset.rubrique || '';
          applyFilters();
        });
      });

      tagButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedTag = button.dataset.tag || '';
          applyFilters();
        });
      });

      searchInput?.addEventListener('input', applyFilters);

      document.getElementById('blog-filters')?.addEventListener('submit', (event) => {
        event.preventDefault();
        applyFilters();
      });

      applyFilters();

      const themeBtn = document.getElementById('theme-toggle');
      const mobileThemeBtn = document.getElementById('mobile-theme-btn');
      const body = document.body;
      let lastFocusedElement = null;

      function syncThemeControl() {
        const isLight = body.classList.contains('light-mode');
        const icon = isLight ? '☀️' : '🌙';
        const actionLabel = isLight ? 'Activer le thème sombre' : 'Activer le thème clair';

        if (themeBtn) {
          themeBtn.innerHTML = isLight
            ? '<span class="icon-light">☀️</span>'
            : '<span class="icon-dark">🌙</span>';
          themeBtn.setAttribute('aria-label', actionLabel);
          themeBtn.setAttribute('aria-pressed', String(isLight));
        }

        if (mobileThemeBtn) {
          mobileThemeBtn.textContent = icon;
          mobileThemeBtn.setAttribute('aria-label', actionLabel);
          mobileThemeBtn.setAttribute('aria-pressed', String(isLight));
        }
      }

      if (localStorage.getItem('theme') === 'light') {
        body.classList.add('light-mode');
      }

      syncThemeControl();

      function toggleTheme() {
        body.classList.toggle('light-mode');
        const isLight = body.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        syncThemeControl();
      }

      themeBtn?.addEventListener('click', toggleTheme);
      mobileThemeBtn?.addEventListener('click', toggleTheme);

      const burgerBtn = document.getElementById('burger-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      if (burgerBtn && mobileMenu) {
        const mobileFocusableSelector =
          'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

        const getMenuFocusableElements = () =>
          Array.from(mobileMenu.querySelectorAll(mobileFocusableSelector)).filter(
            (element) => !element.hasAttribute('hidden'),
          );

        const setMenuState = (isOpen) => {
          mobileMenu.classList.toggle('active', isOpen);
          burgerBtn.classList.toggle('active', isOpen);
          burgerBtn.setAttribute('aria-expanded', String(isOpen));
          burgerBtn.setAttribute(
            'aria-label',
            isOpen ? 'Fermer le menu principal' : 'Ouvrir le menu principal',
          );
          mobileMenu.hidden = !isOpen;
          mobileMenu.setAttribute('aria-hidden', String(!isOpen));
          if (isOpen) {
            mobileMenu.removeAttribute('inert');
          } else {
            mobileMenu.setAttribute('inert', '');
          }
          document.body.style.overflow = isOpen ? 'hidden' : '';

          const navRight = document.querySelector('.nav-right');
          const mainContent = document.getElementById('main-content');
          const footer = document.querySelector('.footer');

          [navRight, mainContent, footer].forEach((element) => {
            if (!element) return;
            if (isOpen) {
              element.setAttribute('inert', '');
            } else {
              element.removeAttribute('inert');
            }
          });

          if (isOpen) {
            lastFocusedElement = document.activeElement;
            window.setTimeout(() => {
              getMenuFocusableElements()[0]?.focus();
            }, 0);
          } else if (lastFocusedElement instanceof HTMLElement) {
            lastFocusedElement.focus();
            lastFocusedElement = null;
          }
        };

        setMenuState(false);

        burgerBtn.addEventListener('click', () => {
          const isOpen = burgerBtn.getAttribute('aria-expanded') !== 'true';
          setMenuState(isOpen);
        });

        document.querySelectorAll('.mobile-item').forEach((item) => {
          item.addEventListener('click', () => {
            setMenuState(false);
          });
        });

        document.addEventListener('keydown', (event) => {
          const menuIsOpen = burgerBtn.getAttribute('aria-expanded') === 'true';

          if (event.key === 'Escape' && menuIsOpen) {
            setMenuState(false);
            return;
          }

          if (event.key === 'Tab' && menuIsOpen) {
            const focusableElements = getMenuFocusableElements();
            if (focusableElements.length === 0) return;

            const firstElement = focusableElements[0];
            const lastElement = focusableElements[focusableElements.length - 1];
            const activeElement = document.activeElement;

            if (event.shiftKey && activeElement === firstElement) {
              event.preventDefault();
              lastElement.focus();
            } else if (!event.shiftKey && activeElement === lastElement) {
              event.preventDefault();
              firstElement.focus();
            }
          }
        });
      }
    </script>
        </>
      )
    }
  </body>
</html>

<style>
  :root {
    --bg-body: #0b1120;
    --bg-card: #151e32;
    --text-main: #f1f5f9;
    --text-muted: #94a3b8;
    --brand-green: #2dd4bf;
    --brand-orange: #f97316;
    --brand-blue: #38bdf8;
    --border-color: rgba(255, 255, 255, 0.08);
    --field-border: rgba(148, 163, 184, 0.52);
    --field-placeholder: #cbd5e1;
    --field-input-bg: #101a31;
    --field-input-border: #8ca0ba;
    --action-bg: #14b8a6;
    --action-text: #052e2b;
    --glow-opacity: 0.15;
    --nav-height: 70px;
  }

  body.light-mode {
    --bg-body: #f8fafc;
    --bg-card: #ffffff;
    --text-main: #1e293b;
    --text-muted: #64748b;
    --brand-green: #0f766e;
    --brand-orange: #c2410c;
    --brand-blue: #0369a1;
    --border-color: rgba(0, 0, 0, 0.08);
