---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, 'fr'),
);
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog | Le Singe Du Numérique</title>
    <meta
      name="description"
      content="Articles, tutoriels et retours d'expérience de l'association Le Singe Du Numérique."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>

    <nav class="navbar" aria-label="Navigation du blog">
      <div class="container nav-container">
        <a href="/" class="brand-logo">
          <img src="/logo.svg" alt="Le Singe Du Numérique" class="navbar-logo" />
          <span class="brand-text">Le Singe Du Numérique</span>
        </a>
        <div class="nav-right">
          <div class="nav-links">
            <a href="/projets" class="nav-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
            <a href="/asso" class="nav-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a>
            <a href="/evenements" class="nav-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
            <a href="/adhesion" class="nav-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a>
            <a href="/blog" class="nav-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
          </div>
          <button
            id="theme-toggle"
            class="theme-btn"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            <span class="icon-light">☀️</span>
            <span class="icon-dark">🌙</span>
          </button>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <section class="hero-section">
        <div class="glow-bg glow-green"></div>
        <div class="glow-bg glow-orange"></div>

        <div class="container hero-content">
          <p class="eyebrow">Blog</p>
          <h1 class="hero-title">
            Des ressources pour <span class="gradient-text">coder mieux</span>
          </h1>
          <p class="hero-desc">
            Recherche par mot-clé, filtre par tag, puis parcours des articles existants.
          </p>

          <div class="hero-meta">
            <span id="results-count" aria-live="polite">{posts.length} article{posts.length > 1 ? 's' : ''}</span>
            <span>•</span>
            <span>{allTags.length} tag{allTags.length > 1 ? 's' : ''}</span>
          </div>

          <form class="search-panel" id="blog-filters" action="/blog" method="get">
            <label class="sr-only" for="blog-search">Recherche dans les articles du blog</label>
            <div class="search-bar">
              <span class="search-icon" aria-hidden="true">
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
              </span>
              <input
                id="blog-search"
                name="search"
                type="search"
                placeholder="Rechercher un article, un auteur ou un sujet..."
                class="search-input"
                autocomplete="off"
              />
              <button type="submit" class="search-button">Rechercher</button>
            </div>

            <div class="filters-row">
              <div class="filter-group" role="group" aria-labelledby="tag-filter-label">
                <span class="filter-label" id="tag-filter-label">Tags</span>
                <div class="tag-cloud">
                  <button type="button" class="cloud-tag is-active" data-tag="" aria-pressed="true">Tous les tags</button>
                  {allTags.map((tag) => (
                    <button type="button" class="cloud-tag" data-tag={tag} aria-pressed="false">{tag}</button>
                  ))}
                </div>
              </div>

              <a href="/blog" class="reset-link">Réinitialiser les filtres</a>
            </div>
          </form>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Derniers <span class="text-accent">articles</span></h2>
            <div class="line-deco"></div>
          </div>

          <p class="empty-state" id="empty-state" hidden aria-live="polite">Aucun article ne correspond à ce filtre pour le moment.</p>

          <div class="posts-grid" id="posts-grid">
            {posts.map((post, index) => {
              const searchable = [
                post.data.title,
                post.data.description,
                post.data.author ?? '',
                ...post.data.tags,
              ].join(' ');
              return (
                <article
                  class={`post-card ${index === 0 ? 'featured' : ''}`}
                  data-tags={post.data.tags.join('|')}
                  data-searchable={searchable}
                >
                  <div class={`card-top ${index % 3 === 0 ? 'card-green' : index % 3 === 1 ? 'card-orange' : 'card-blue'}`}>
                    <span class="card-kicker">
                      {post.data.pubDate.toLocaleDateString('fr-FR', {
                        day: 'numeric',
                        month: 'short',
                        year: 'numeric',
                      })}
                    </span>
                  </div>

                  <div class="post-content">
                    <div class="tag-list">
                      {post.data.tags.map((tag) => (
                        <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
                      ))}
                    </div>

                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>

                    <a href={`/blog/${post.id}/`} class="post-link">
                      Lire l'article
                      <span aria-hidden="true">→</span>
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <img src="/logo.svg" alt="Le Singe Du Numérique" class="footer-logo" />
          <span>Le Singe Du Numérique</span>
        </div>
        <div class="footer-links">
          <a href="/accessibilite">Accessibilité : non conforme</a>
          <span class="footer-separator">•</span>
          <a href="/projets">Projets</a>
          <span class="footer-separator">•</span>
          <a href="/asso">L’association</a>
          <span class="footer-separator">•</span>
          <a href="/evenements">Événements</a>
          <span class="footer-separator">•</span>
          <a href="/adhesion">Rejoindre</a>
          <span class="footer-separator">•</span>
          <a href="/blog">Blog</a>
          <span class="footer-separator">•</span>
          <a href="/mentions-legales">Mentions légales</a>
        </div>
      </div>
    </footer>

    <script>
      const params = new URLSearchParams(window.location.search);
      const normalize = (value) =>
        (value || '')
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .toLowerCase()
          .trim();

      const searchInput = document.getElementById('blog-search');
      const tagButtons = Array.from(document.querySelectorAll('[data-tag]'));
      const cards = Array.from(document.querySelectorAll('.post-card'));
      const countNode = document.getElementById('results-count');
      const emptyState = document.getElementById('empty-state');

      let selectedTag = params.get('tag') || '';

      if (searchInput) {
        searchInput.value = params.get('search') || '';
      }

      function syncTagButtons() {
        const normalizedTag = normalize(selectedTag);
        tagButtons.forEach((button) => {
          const isActive = normalize(button.dataset.tag || '') === normalizedTag;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-pressed', String(isActive));
        });
      }

      function updateUrl(searchTerm) {
        const nextParams = new URLSearchParams();
        if (searchTerm) nextParams.set('search', searchTerm);
        if (selectedTag) nextParams.set('tag', selectedTag);
        const nextQuery = nextParams.toString();
        const nextUrl = nextQuery ? `/blog?${nextQuery}` : '/blog';
        window.history.replaceState({}, '', nextUrl);
      }

      function applyFilters() {
        const searchTerm = normalize(searchInput?.value || '');
        const normalizedTag = normalize(selectedTag);
        let visibleCount = 0;

        cards.forEach((card) => {
          const searchable = normalize(card.dataset.searchable || '');
          const tags = (card.dataset.tags || '').split('|').map(normalize);
          const matchesSearch = !searchTerm || searchable.includes(searchTerm);
          const matchesTag = !normalizedTag || tags.includes(normalizedTag);
          const visible = matchesSearch && matchesTag;
          card.hidden = !visible;
          if (visible) visibleCount += 1;
        });

        if (countNode) {
          countNode.textContent = `${visibleCount} article${visibleCount > 1 ? 's' : ''}`;
        }

        if (emptyState) {
          emptyState.hidden = visibleCount !== 0;
        }

        syncTagButtons();
        updateUrl(searchTerm);
      }

      tagButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedTag = button.dataset.tag || '';
          applyFilters();
        });
      });

      searchInput?.addEventListener('input', applyFilters);

      document.getElementById('blog-filters')?.addEventListener('submit', (event) => {
        event.preventDefault();
        applyFilters();
      });

      applyFilters();

      const themeBtn = document.getElementById('theme-toggle');
      const body = document.body;

      function syncThemeControl() {
        const isLight = body.classList.contains('light-mode');
        const actionLabel = isLight ? 'Activer le thème sombre' : 'Activer le thème clair';

        if (themeBtn) {
          themeBtn.innerHTML = isLight
            ? '<span class="icon-light">☀️</span>'
            : '<span class="icon-dark">🌙</span>';
          themeBtn.setAttribute('aria-label', actionLabel);
          themeBtn.setAttribute('aria-pressed', String(isLight));
        }
      }

      if (localStorage.getItem('theme') === 'light') {
        body.classList.add('light-mode');
      }

      syncThemeControl();

      themeBtn?.addEventListener('click', () => {
        body.classList.toggle('light-mode');
        const isLight = body.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        syncThemeControl();
      });
    </script>
  </body>
</html>

<style>
  :root {
    --bg-body: #0b1120;
    --bg-card: #151e32;
    --text-main: #f1f5f9;
    --text-muted: #94a3b8;
    --brand-green: #2dd4bf;
    --brand-orange: #f97316;
    --brand-blue: #38bdf8;
    --border-color: rgba(255, 255, 255, 0.08);
    --glow-opacity: 0.15;
  }

  body.light-mode {
    --bg-body: #f8fafc;
    --bg-card: #ffffff;
    --text-main: #1e293b;
    --text-muted: #64748b;
    --brand-green: #0f766e;
    --brand-orange: #c2410c;
    --brand-blue: #0369a1;
    --border-color: rgba(0, 0, 0, 0.08);
    --glow-opacity: 0.08;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg-body);
    color: var(--text-main);
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible,
  [tabindex]:focus-visible {
    outline: 3px solid var(--brand-green);
    outline-offset: 3px;
  }

  .skip-link {
    position: absolute;
    left: 16px;
    top: -48px;
    z-index: 200;
    padding: 10px 14px;
    border-radius: 12px;
    background: #ffffff;
    color: #07131d;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .skip-link:focus {
    top: 16px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  button,
  input {
    font: inherit;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .navbar {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 16px 0;
    background: rgba(11, 17, 32, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  body.light-mode .navbar {
    background: rgba(248, 250, 252, 0.85);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .navbar-logo,
  .footer-logo {
    width: auto;
    height: 40px;
    display: block;
  }

  .brand-text {
    display: none;
  }

  .nav-links,
  .footer-links {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .nav-item,
  .footer-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .nav-item:hover,
  .footer-links a:hover {
    color: var(--brand-green);
  }

  .nav-item[aria-current='page'] {
    color: var(--text-main);
  }

  .theme-btn {
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    color: var(--text-main);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
  }

  .theme-btn:hover {
    border-color: var(--brand-green);
    background: rgba(128, 128, 128, 0.1);
  }

  .icon-dark { display: block; }
  .icon-light { display: none; }

  body.light-mode .icon-dark { display: none; }
  body.light-mode .icon-light { display: block; }

  .hero-section {
    position: relative;
    overflow: hidden;
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .glow-bg {
    position: absolute;
    z-index: -1;
    border-radius: 50%;
    filter: blur(90px);
    opacity: var(--glow-opacity);
  }

  .glow-green {
    top: -100px;
    left: -100px;
    width: 360px;
    height: 360px;
    background: var(--brand-green);
  }

  .glow-orange {
    top: 40px;
    right: -120px;
    width: 420px;
    height: 420px;
    background: var(--brand-orange);
  }

  .hero-content {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-green);
  }

  .hero-title {
    margin: 0 0 1rem;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--brand-green), var(--brand-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    margin: 0 auto 1.5rem;
    max-width: 620px;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .hero-meta {
    display: inline-flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
  }

  .search-panel {
    display: grid;
    gap: 14px;
    text-align: left;
  }

  .search-bar {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
  }

  .search-bar:focus-within {
    border-color: rgba(45, 212, 191, 0.55);
    box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.12);
  }

  .search-icon {
    color: var(--text-muted);
    display: flex;
    align-items: center;
  }

  .search-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    color: var(--text-main);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-button {
    border: none;
    border-radius: 999px;
    padding: 10px 14px;
    background: linear-gradient(135deg, var(--brand-green), var(--brand-blue));
    color: #07131d;
    font-weight: 700;
    cursor: pointer;
  }

  .filters-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }

  .filter-group {
    display: grid;
    gap: 10px;
  }

  .filter-label {
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .cloud-tag,
  .tag-pill {
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem;
  }

  .cloud-tag {
    cursor: pointer;
  }

  .cloud-tag:hover,
  .cloud-tag:focus-visible,
  .tag-pill:hover,
  .tag-pill:focus-visible,
  .post-link:focus-visible,
  .reset-link:focus-visible {
    color: var(--brand-green);
    border-color: rgba(45, 212, 191, 0.45);
  }

  .cloud-tag.is-active {
    border-color: rgba(45, 212, 191, 0.45);
    background: rgba(45, 212, 191, 0.14);
    color: var(--brand-green);
  }

  .reset-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .reset-link:hover {
    color: var(--brand-green);
  }

  .content-section {
    padding: 2rem 0 4rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 2rem;
    color: var(--text-main);
  }

  .text-accent {
    color: var(--brand-green);
  }

  .line-deco {
    flex: 1;
    height: 1px;
    background: var(--border-color);
  }

  .empty-state {
    margin: 0 0 1rem;
    color: var(--text-muted);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 22px;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .post-card:hover {
    transform: translateY(-6px);
    border-color: rgba(45, 212, 191, 0.5);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .featured {
    grid-column: span 2;
  }

  .card-top {
    padding: 18px 20px;
    min-height: 96px;
    display: flex;
    align-items: flex-end;
  }

  .card-green {
    background: linear-gradient(135deg, #10b981, #059669);
  }

  .card-orange {
    background: linear-gradient(135deg, #f97316, #ea580c);
  }

  .card-blue {
    background: linear-gradient(135deg, #0ea5e9, #0284c7);
  }

  .card-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(11, 17, 32, 0.48);
    color: #f8fafc;
    backdrop-filter: blur(6px);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.4rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .post-content h3 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.15;
  }

  .post-content p {
    margin: 0;
    color: var(--text-muted);
  }

  .post-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    color: var(--brand-green);
    font-weight: 700;
  }

  .post-link:hover {
    gap: 12px;
  }

  .footer {
    padding: 28px 0 40px;
    border-top: 1px solid var(--border-color);
  }

  body.light-mode .footer {
    background: rgba(255, 255, 255, 0.88);
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
  }

  .footer-separator {
    color: var(--text-muted);
  }

  @media (min-width: 768px) {
    .brand-text {
      display: inline;
    }
  }

  @media (max-width: 900px) {
    .featured {
      grid-column: span 1;
    }
  }

  @media (max-width: 640px) {
    .nav-container,
    .footer-container,
    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .nav-right {
      width: 100%;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .search-bar {
      flex-wrap: wrap;
