---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, 'fr'),
);
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog | Le Singe Du Numérique</title>
    <meta
      name="description"
      content="Articles, tutoriels et retours d'expérience de l'association Le Singe Du Numérique."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="brand-logo">
          <img src="/logo.svg" alt="Logo" class="navbar-logo" />
          <span class="brand-text">Le Singe Du Numérique</span>
        </a>
        <a href="/" class="back-home">← Retour à l'accueil</a>
      </div>
    </nav>

    <main>
      <section class="hero-section">
        <div class="glow-bg glow-green"></div>
        <div class="glow-bg glow-orange"></div>

        <div class="container hero-content">
          <p class="eyebrow">Blog</p>
          <h1 class="hero-title">
            Des ressources pour <span class="gradient-text">coder mieux</span>
          </h1>
          <p class="hero-desc">
            Tutoriels, billets techniques et nouvelles de l'association. Le contenu est encore en
            construction, mais la base est là.
          </p>

          <div class="hero-meta">
            <span>{posts.length} article{posts.length > 1 ? 's' : ''}</span>
            <span>•</span>
            <span>{allTags.length} tag{allTags.length > 1 ? 's' : ''}</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Derniers <span class="text-accent">articles</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="posts-grid">
            {posts.map((post, index) => (
              <article class={`post-card ${index === 0 ? 'featured' : ''}`}>
                <div class={`card-top ${index % 3 === 0 ? 'card-green' : index % 3 === 1 ? 'card-orange' : 'card-blue'}`}>
                  <span class="card-kicker">
                    {post.data.pubDate.toLocaleDateString('fr-FR', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric',
                    })}
                  </span>
                </div>

                <div class="post-content">
                  <div class="tag-list">
                    {post.data.tags.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>

                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>

                  <a href={`/blog/${post.id}/`} class="post-link">
                    Lire l'article
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="content-section compact-top">
        <div class="container">
          <div class="section-header">
            <h2>Explorer par <span class="text-accent">tag</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="tag-cloud">
            {allTags.map((tag) => (
              <span class="cloud-tag">{tag}</span>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <img src="/logo.svg" alt="Logo" class="footer-logo" />
          <span>Le Singe Du Numérique</span>
        </div>
        <span class="footer-credit">Fait avec ❤️ et du code éthique © 2026</span>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg-body: #0b1120;
    --bg-card: #151e32;
    --text-main: #f1f5f9;
    --text-muted: #94a3b8;
    --brand-green: #2dd4bf;
    --brand-orange: #f97316;
    --brand-blue: #38bdf8;
    --border-color: rgba(255, 255, 255, 0.08);
    --glow-opacity: 0.15;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg-body);
    color: var(--text-main);
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .navbar {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 16px 0;
    background: rgba(11, 17, 32, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .navbar-logo,
  .footer-logo {
    width: auto;
    height: 40px;
    display: block;
  }

  .brand-text {
    display: none;
  }

  .back-home {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .back-home:hover {
    color: var(--brand-green);
  }

  .hero-section {
    position: relative;
    overflow: hidden;
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .glow-bg {
    position: absolute;
    z-index: -1;
    border-radius: 50%;
    filter: blur(90px);
    opacity: var(--glow-opacity);
  }

  .glow-green {
    top: -100px;
    left: -100px;
    width: 360px;
    height: 360px;
    background: var(--brand-green);
  }

  .glow-orange {
    top: 40px;
    right: -120px;
    width: 420px;
    height: 420px;
    background: var(--brand-orange);
  }

  .hero-content {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-green);
  }

  .hero-title {
    margin: 0 0 1rem;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--brand-green), var(--brand-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    margin: 0 auto 1.5rem;
    max-width: 620px;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .hero-meta {
    display: inline-flex;
    gap: 12px;
    align-items: center;
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
  }

  .content-section {
    padding: 2rem 0 4rem;
  }

  .compact-top {
    padding-top: 0;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 2rem;
    color: var(--text-main);
  }

  .text-accent {
    color: var(--brand-green);
  }

  .line-deco {
    flex: 1;
    height: 1px;
    background: var(--border-color);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .post-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 22px;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .post-card:hover {
    transform: translateY(-6px);
    border-color: rgba(45, 212, 191, 0.5);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.22);
  }

  .featured {
    grid-column: span 2;
  }

  .card-top {
    padding: 18px 20px;
    min-height: 96px;
    display: flex;
    align-items: flex-end;
  }

  .card-green {
    background: linear-gradient(135deg, #10b981, #059669);
  }

  .card-orange {
    background: linear-gradient(135deg, #f97316, #ea580c);
  }

  .card-blue {
    background: linear-gradient(135deg, #0ea5e9, #0284c7);
  }

  .card-kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(11, 17, 32, 0.28);
    backdrop-filter: blur(6px);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.4rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-list span,
  .cloud-tag {
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
  }

  .post-content h3 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.15;
  }

  .post-content p {
    margin: 0;
    color: var(--text-muted);
  }

  .post-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    color: var(--brand-green);
    font-weight: 700;
  }

  .post-link:hover {
    gap: 12px;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .cloud-tag {
    color: var(--text-main);
  }

  .footer {
    padding: 28px 0 40px;
    border-top: 1px solid var(--border-color);
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
  }

  .footer-credit {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .brand-text {
      display: inline;
    }
  }

  @media (max-width: 900px) {
    .featured {
      grid-column: span 1;
    }
  }

  @media (max-width: 640px) {
    .nav-container,
    .footer-container,
    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-section {
      padding-top: 3rem;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
