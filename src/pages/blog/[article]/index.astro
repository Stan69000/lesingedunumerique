---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');
  return allEntries.map((entry) => ({
    params: { article: entry.id },
  }));
}

const { article } = Astro.params;
const allEntries = await getCollection('blog');
const post = allEntries.find((entry) => entry.id === article);

if (!post) {
  return new Response('Not Found', { status: 404 });
}

const { Content } = await render(post);
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>{post.data.title} - Le Singe Du Numérique</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={post.data.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg-body: #0b1120;
        --bg-card: #151e32;
        --text-main: #f1f5f9;
        --text-muted: #94a3b8;
        --accent: #2dd4bf;
        --accent-alt: #38bdf8;
        --border: #334155;
        --code-bg: #1e293b;
      }

      * { box-sizing: border-box; }

      body {
        background-color: var(--bg-body);
        color: var(--text-main);
        font-family: 'Space Grotesk', sans-serif;
        margin: 0;
        line-height: 1.7;
      }

      a { color: inherit; text-decoration: none; }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      textarea:focus-visible,
      select:focus-visible,
      [tabindex]:focus-visible {
        outline: 3px solid var(--accent);
        outline-offset: 3px;
      }

      .skip-link {
        position: absolute;
        left: 16px;
        top: -48px;
        z-index: 10;
        padding: 10px 14px;
        border-radius: 12px;
        background: #ffffff;
        color: #07131d;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
      }

      .skip-link:focus { top: 16px; }

      .page-shell {
        position: relative;
        overflow: hidden;
        min-height: 100vh;
      }

      .glow-bg {
        position: absolute;
        z-index: 0;
        border-radius: 50%;
        filter: blur(90px);
        opacity: 0.14;
      }

      .glow-left {
        top: -80px;
        left: -120px;
        width: 320px;
        height: 320px;
        background: var(--accent);
      }

      .glow-right {
        top: 80px;
        right: -140px;
        width: 420px;
        height: 420px;
        background: var(--accent-alt);
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 860px;
        margin: 0 auto;
        padding: 40px 20px;
      }

      .nav-back {
        display: inline-flex; align-items: center; gap: 8px; margin-bottom: 30px; color: var(--text-muted);
        font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;
      }
      .nav-back:hover { color: var(--accent); }

      header {
        text-align: center; margin-bottom: 50px; padding: 30px;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        background: rgba(21, 30, 50, 0.72);
        backdrop-filter: blur(10px);
      }

      .tags { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
      .tag {
        background: rgba(45, 212, 191, 0.1); color: var(--accent);
        padding: 4px 12px; border-radius: 20px; font-size: 0.85rem;
        font-family: 'JetBrains Mono', monospace; font-weight: 500;
      }

      h1 { font-size: 2.5rem; color: #fff; margin: 0 0 15px 0; line-height: 1.2; letter-spacing: -0.02em; }
      .meta { color: var(--text-muted); font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; }

      .article-content {
        font-size: 1.15rem;
        color: #e2e8f0;
        background: rgba(21, 30, 50, 0.5);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 24px;
        padding: 30px;
      }
      .article-content :global(h2) { color: #fff; margin-top: 40px; font-size: 1.8rem; border-left: 4px solid var(--accent); padding-left: 15px; }
      .article-content :global(h3) { color: #fff; margin-top: 30px; font-size: 1.4rem; }
      .article-content :global(p) { margin-bottom: 1.5rem; line-height: 1.8; }
      .article-content :global(ul),
      .article-content :global(ol) { margin-bottom: 1.5rem; padding-left: 20px; color: var(--text-muted); }
      .article-content :global(li) { margin-bottom: 0.5rem; }

      .article-content :global(pre) {
        background: var(--code-bg); padding: 20px; border-radius: 8px;
        overflow-x: auto; border: 1px solid var(--border);
        font-family: 'Courier New', Courier, monospace; font-size: 0.9rem; color: #f1f5f9; margin: 25px 0;
      }
      .article-content :global(code) {
        background: rgba(45, 212, 191, 0.1); color: var(--accent);
        padding: 2px 6px; border-radius: 4px; font-family: 'Courier New', Courier, monospace; font-size: 0.9em;
      }
      .article-content :global(pre code) { background: transparent; color: inherit; padding: 0; }

      .article-content :global(blockquote) {
        border-left: 4px solid var(--accent); margin: 30px 0; padding-left: 20px;
        color: var(--text-muted); font-style: italic;
        background: rgba(255,255,255,0.02); padding: 15px 20px; border-radius: 0 8px 8px 0;
      }
      .article-content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 20px 0; border: 1px solid var(--border); }

      footer {
        margin-top: 60px; padding-top: 30px; border-top: 1px solid var(--border);
        text-align: center; color: var(--text-muted); font-size: 0.9rem;
      }

      .footer-links {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 12px;
      }

      .footer-links a:hover {
        color: var(--accent);
      }

      @media (max-width: 640px) {
        header,
        .article-content {
          padding: 22px;
        }

        h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <a class="skip-link" href="#main-content">Aller au contenu principal</a>
      <div class="glow-bg glow-left"></div>
      <div class="glow-bg glow-right"></div>
      <div class="container">
      <nav aria-label="Navigation de l'article">
        <a href="/blog" class="nav-back">← Retour au blog</a>
      </nav>

      <main id="main-content">
      <article>
        <header>
          <div class="tags">
            {post.data.tags.map((tag) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
          <h1>{post.data.title}</h1>
          <div class="meta">
            Par {post.data.author} • {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </div>
        </header>

        <div class="article-content">
          <Content />
        </div>
      </article>
      </main>

      <footer>
        <p>© 2026 Le Singe Du Numérique. Code éthique & Open Source.</p>
        <div class="footer-links">
          <a href="/accessibilite">Accessibilité : non conforme</a>
          <a href="/mentions-legales">Mentions légales</a>
        </div>
      </footer>
      </div>
    </div>
  </body>
</html>
