---
import { getCollection, render } from 'astro:content';
import MaintenanceContent from '../../../components/MaintenanceContent.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import { siteSettings } from '../../../config/site';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');
  return allEntries.map((entry) => ({
    params: { article: entry.id },
  }));
}

const { article } = Astro.params;
const allEntries = await getCollection('blog');
const post = allEntries.find((entry) => entry.id === article);
const currentPath = Astro.url.pathname;

if (!post) {
  return new Response('Not Found', { status: 404 });
}

const { Content } = await render(post);
const canonicalUrl = new URL(currentPath, siteSettings.siteUrl).toString();
const articleTitle = `${post.data.title} | ${siteSettings.siteName}`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author || siteSettings.siteName,
  },
  publisher: {
    '@type': 'Organization',
    name: siteSettings.siteName,
    logo: {
      '@type': 'ImageObject',
      url: `${siteSettings.siteUrl}/logo.svg`,
    },
  },
  mainEntityOfPage: canonicalUrl,
  image: `${siteSettings.siteUrl}/logo.svg`,
  inLanguage: 'fr-FR',
};
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>{articleTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={post.data.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={articleTitle} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <meta property="article:published_time" content={post.data.pubDate.toISOString()} />
    <meta property="article:author" content={post.data.author || siteSettings.siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={articleTitle} />
    <meta name="twitter:description" content={post.data.description} />
    <meta name="twitter:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
    <style>
      :root {
        --bg-body: #0b1120;
        --bg-card: #151e32;
        --text-main: #f1f5f9;
        --text-muted: #94a3b8;
        --accent: #2dd4bf;
        --accent-alt: #38bdf8;
        --border: #334155;
        --code-bg: #1e293b;
      }

      body.light-mode {
        --bg-body: #f8fafc;
        --bg-card: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --accent: #0f766e;
        --accent-alt: #0369a1;
        --border: #cbd5e1;
        --code-bg: #e2e8f0;
      }

      * { box-sizing: border-box; }

      body {
        background-color: var(--bg-body);
        color: var(--text-main);
        font-family: 'Space Grotesk', sans-serif;
        margin: 0;
        line-height: 1.7;
      }

      a { color: inherit; text-decoration: none; }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      textarea:focus-visible,
      select:focus-visible,
      [tabindex]:focus-visible {
        outline: 3px solid var(--accent);
        outline-offset: 3px;
      }

      .skip-link {
        position: absolute;
        left: 16px;
        top: -48px;
        z-index: 10;
        padding: 10px 14px;
        border-radius: 12px;
        background: #ffffff;
        color: #07131d;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
      }

      .skip-link:focus { top: 16px; }

      .page-shell {
        position: relative;
        overflow: hidden;
        min-height: 100vh;
      }

      .glow-bg {
        position: absolute;
        z-index: 0;
        border-radius: 50%;
        filter: blur(90px);
        opacity: 0.14;
      }

      .glow-left {
        top: -80px;
        left: -120px;
        width: 320px;
        height: 320px;
        background: var(--accent);
      }

      .glow-right {
        top: 80px;
        right: -140px;
        width: 420px;
        height: 420px;
        background: var(--accent-alt);
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 20px;
      }

      .article-shell {
        max-width: 860px;
        margin: 0 auto;
      }

      .navbar {
        margin-bottom: 30px;
      }

      body.light-mode .navbar {
        background: rgba(248, 250, 252, 0.85);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 20;
        padding: 16px 0;
      }

      .navbar {
        background: rgba(11, 17, 32, 0.85);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 20;
        padding: 16px 0;
      }

      .nav-container,
      .footer-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
      }

      .brand-logo,
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 700;
      }

      .navbar-logo,
      .footer-logo {
        height: 40px;
        width: auto;
        display: block;
      }

      .brand-text {
        display: none;
      }

      .nav-links,
      .footer-links {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .nav-item,
      .footer-links a {
        color: var(--text-muted);
        font-size: 0.95rem;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      .nav-item[aria-current='page'] {
        color: var(--text-main);
      }

      .nav-item:hover,
      .footer-links a:hover {
        color: var(--accent);
      }

      .theme-btn {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 50%;
        width: 38px;
        height: 38px;
        color: var(--text-main);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
      }

      .theme-btn:hover {
        border-color: var(--accent);
        background: rgba(128, 128, 128, 0.1);
      }

      .icon-dark { display: block; }
      .icon-light { display: none; }

      body.light-mode .icon-dark { display: none; }
      body.light-mode .icon-light { display: block; }

      header {
        text-align: center; margin-bottom: 50px; padding: 30px;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        background: rgba(21, 30, 50, 0.72);
        backdrop-filter: blur(10px);
      }

      body.light-mode header {
        background: rgba(255, 255, 255, 0.9);
      }

      .tags { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
      .tag {
        background: rgba(45, 212, 191, 0.1); color: var(--accent);
        padding: 6px 12px; border-radius: 20px; font-size: 0.9rem;
        font-weight: 500;
      }

      h1 { font-size: 2.5rem; color: #fff; margin: 0 0 15px 0; line-height: 1.2; letter-spacing: -0.02em; }
      .meta { color: var(--text-muted); font-size: 1rem; font-weight: 500; }

      .article-content {
        font-size: 1.12rem;
        color: #e2e8f0;
        background: rgba(21, 30, 50, 0.5);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 24px;
        padding: 34px;
      }

      body.light-mode .article-content {
        color: #334155;
        background: rgba(255, 255, 255, 0.9);
      }

      body.light-mode .article-content :global(h2),
      body.light-mode .article-content :global(h3) {
        color: #0f172a;
      }
      .article-content :global(h2) { color: #fff; margin-top: 40px; font-size: 1.8rem; border-left: 4px solid var(--accent); padding-left: 15px; }
      .article-content :global(h3) { color: #fff; margin-top: 30px; font-size: 1.4rem; }
      .article-content :global(p) { margin-bottom: 1.5rem; line-height: 1.8; }
      .article-content :global(ul),
      .article-content :global(ol) { margin-bottom: 1.5rem; padding-left: 20px; color: var(--text-muted); }
      .article-content :global(li) { margin-bottom: 0.5rem; }

      .article-content :global(pre) {
        background: var(--code-bg); padding: 20px; border-radius: 8px;
        overflow-x: auto; border: 1px solid var(--border);
        font-family: 'Courier New', Courier, monospace; font-size: 0.9rem; color: #f1f5f9; margin: 25px 0;
      }
      .article-content :global(code) {
        background: rgba(45, 212, 191, 0.1); color: var(--accent);
        padding: 2px 6px; border-radius: 4px; font-family: 'Courier New', Courier, monospace; font-size: 0.9em;
      }
      .article-content :global(pre code) { background: transparent; color: inherit; padding: 0; }

      .article-content :global(blockquote) {
        border-left: 4px solid var(--accent); margin: 30px 0; padding-left: 20px;
        color: var(--text-muted); font-style: italic;
        background: rgba(255,255,255,0.02); padding: 15px 20px; border-radius: 0 8px 8px 0;
      }
      .article-content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 20px 0; border: 1px solid var(--border); }
      .article-content :global(.article-gallery) {
        display: grid;
        gap: 18px;
        margin: 28px 0 34px;
      }
      .article-content :global(.article-gallery-two) {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .article-content :global(.article-gallery figure) {
        margin: 0;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 12px;
      }
      body.light-mode .article-content :global(.article-gallery figure) {
        background: rgba(15, 23, 42, 0.03);
      }
      .article-content :global(.article-gallery img) {
        display: block;
        width: 100%;
        max-height: 280px;
        object-fit: cover;
        margin: 0;
      }
      .article-content :global(.article-gallery figcaption) {
        margin-top: 10px;
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.55;
      }
      .article-content :global(.pdf-embed) {
        margin: 28px 0 34px;
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        background: rgba(255,255,255,0.03);
      }
      body.light-mode .article-content :global(.pdf-embed) {
        background: rgba(15, 23, 42, 0.03);
      }
      .article-content :global(.pdf-embed iframe) {
        display: block;
        width: 100%;
        min-height: 720px;
        border: 0;
        background: #fff;
      }

      footer {
        margin-top: 60px; padding-top: 30px; border-top: 1px solid var(--border);
        color: var(--text-muted); font-size: 0.9rem;
      }

      .back-to-top {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: var(--accent);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px color-mix(in srgb, var(--accent) 45%, transparent);
        z-index: 90;
        opacity: 0;
        transform: translateY(20px);
        pointer-events: none;
        transition: all 0.35s ease;
      }

      .back-to-top.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .back-to-top:hover {
        transform: translateY(-4px);
      }

      @media (max-width: 640px) {
        .nav-container,
        .footer-container {
          flex-direction: column;
          align-items: flex-start;
        }

        .nav-right {
          width: 100%;
          justify-content: space-between;
          gap: 16px;
          flex-wrap: wrap;
        }

        .brand-text {
          display: inline;
        }

        header,
        .article-content {
          padding: 22px;
        }

        .article-content :global(.article-gallery-two) {
          grid-template-columns: 1fr;
        }

        .article-content :global(.pdf-embed iframe) {
          min-height: 520px;
        }

        h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  <body>
    {
      siteSettings.maintenanceMode ? (
        <MaintenanceContent />
      ) : (
        <>
          <div class="page-shell">
            <a class="skip-link" href="#main-content">Aller au contenu principal</a>
            <div class="glow-bg glow-left"></div>
            <div class="glow-bg glow-right"></div>
            <div class="container">
            <nav class="navbar" aria-label="Navigation principale">
              <div class="nav-container">
                <a href="/" class="brand-logo">
                  <img src="/logo.svg" alt="Le Singe Du Numérique" class="navbar-logo" />
                  <span class="brand-text">Le Singe Du Numérique</span>
                </a>
                <div class="nav-right">
                  <div class="nav-links">
                    <a href="/projets" class="nav-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
                    <a href="/asso" class="nav-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a>
                    <a href="/evenements" class="nav-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
                    <a href="/adhesion" class="nav-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a>
                    <a href="/contact" class="nav-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a>
                    <a href="/blog" class="nav-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
                  </div>
                  <button
                    id="theme-toggle"
                    class="theme-btn"
                    type="button"
                    aria-label="Activer le thème clair"
                    aria-pressed="false"
                  >
                    <span class="icon-light">☀️</span>
                    <span class="icon-dark">🌙</span>
                  </button>
                </div>
              </div>
            </nav>

            <div class="article-shell">

            <main id="main-content">
            <article>
              <header>
                <div class="tags">
                  {post.data.tags.map((tag) => (
                    <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
                  ))}
                </div>
                <h1>{post.data.title}</h1>
                <div class="meta">
                  Par {post.data.author} • {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
              </header>

              <div class="article-content">
                <Content />
              </div>

              <ShareButtons title={post.data.title} label="Partager cet article" />
            </article>
            </main>

            <footer>
              <div class="footer-container">
                <div class="footer-brand">
                  <img src="/logo.svg" alt="Le Singe Du Numérique" class="footer-logo" />
                  <span>Le Singe Du Numérique</span>
                </div>
                <div class="footer-links">
                  <a href="/accessibilite">Accessibilité : non conforme</a>
                  <a href="/projets">Projets</a>
                  <a href="/asso">L’association</a>
                  <a href="/evenements">Événements</a>
                  <a href="/adhesion">Rejoindre</a>
                  <a href="/contact">Contact</a>
                  <a href="/blog">Blog</a>
                  <a href="/mentions-legales">Mentions légales</a>
                </div>
              </div>
            </footer>
            <button id="back-to-top" class="back-to-top" aria-label="Retour en haut de page">
              ↑
            </button>
            </div>
            </div>
          </div>
        </>
      )
    }
    <script>
      const themeBtn = document.getElementById('theme-toggle');
      const body = document.body;
      const backToTop = document.getElementById('back-to-top');

      function syncThemeControl() {
        const isLight = body.classList.contains('light-mode');
        const actionLabel = isLight ? 'Activer le thème sombre' : 'Activer le thème clair';

        if (themeBtn) {
          themeBtn.innerHTML = isLight
            ? '<span class="icon-light">☀️</span>'
            : '<span class="icon-dark">🌙</span>';
          themeBtn.setAttribute('aria-label', actionLabel);
          themeBtn.setAttribute('aria-pressed', String(isLight));
        }
      }

      if (localStorage.getItem('theme') === 'light') {
        body.classList.add('light-mode');
      }

      syncThemeControl();

      themeBtn?.addEventListener('click', () => {
        body.classList.toggle('light-mode');
        const isLight = body.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        syncThemeControl();
      });

      function syncBackToTop() {
        if (!backToTop) return;
        backToTop.classList.toggle('visible', window.scrollY > 320);
      }

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      window.addEventListener('scroll', syncBackToTop, { passive: true });
      syncBackToTop();
    </script>
  </body>
</html>
