---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getVeilleData } from '../lib/veille.js';

const veille = await getVeilleData();
const homeSectionKeys = new Set(['arnaques', 'failles']);
const homeSections = veille.sections.filter((section) => homeSectionKeys.has(section.key));
const allArticles = homeSections.flatMap((section) => section.articles);

function normalizeText(value = '') {
  return String(value)
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim();
}

function sourceDomain(url = '') {
  try {
    return new URL(url).hostname.replace(/^www\./i, '').toLowerCase();
  } catch {
    return '';
  }
}

function sourceLabel(article) {
  const source = String(article?.source || '').trim();
  const low = normalizeText(source);
  const domain = sourceDomain(article?.url || '');

  if (!source) return domain || 'Source externe';
  if (low.includes('fuite aujourd') && domain) return domain;
  if (source.length > 38 && domain) return domain;
  return source;
}

function safeHttpUrl(url = '') {
  try {
    const parsed = new URL(url);
    return parsed.protocol === 'http:' || parsed.protocol === 'https:' ? parsed.toString() : '';
  } catch {
    return '';
  }
}

function cleanTag(tag) {
  const value = String(tag || '')
    .trim()
    .replace(/^#+/, '')
    .replace(/[.,;:!?()[\]{}]/g, ' ')
    .replace(/\s+/g, ' ')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-zA-Z0-9\s-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  const blocked = new Set([
    'read',
    'reading-list',
    'saved',
    'starred',
    'broadcast',
    'shared',
    'lock',
    'kept-unread',
    'tracking-kept-unread',
  ]);
  const low = value.toLowerCase();
  if (!value || blocked.has(low) || low.startsWith('state') || low.startsWith('label')) return '';
  return value;
}

function uniqueTags(tags, max = 6) {
  const seen = new Set();
  const out = [];
  for (const raw of tags || []) {
    const normalized = cleanTag(raw);
    const key = normalized.toLowerCase();
    if (!normalized || seen.has(key)) continue;
    seen.add(key);
    out.push(normalized);
    if (out.length >= max) break;
  }
  return out;
}

function sectionDefaultTag(sectionKey = '') {
  if (sectionKey === 'arnaques') return 'arnaque';
  if (sectionKey === 'failles') return 'fuite de données';
  if (sectionKey === 'cyber') return 'cybersécurité';
  if (sectionKey === 'associations') return 'association';
  return 'actualité';
}

function tagsForArticle(article, sectionKey = '') {
  const sectionTag = sectionDefaultTag(sectionKey || article?.blockKey || '');
  const sourceTag = sourceLabel(article)
    .trim()
    .toLowerCase()
    .replace(/^www\./i, '')
    .replace(/\.gouv\.fr$/i, ' gouv')
    .replace(/\.(fr|com|org|net|eu|info)$/i, '')
    .replace(/[^a-z0-9\s-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 20);
  const seed = [sectionTag, ...(article?.tags || [])];
  if (sourceTag && sourceTag.length >= 3) seed.push(sourceTag);
  return uniqueTags(seed, 4);
}

const allSources = [...new Set(allArticles.map((article) => sourceLabel(article)).filter(Boolean))].sort((a, b) =>
  a.localeCompare(b, 'fr'),
);
const allTags = [
  ...new Set(
    allArticles
      .flatMap((article) => tagsForArticle(article, article.blockKey || ''))
      .map((tag) => String(tag).trim())
      .filter((tag) => tag.length >= 3),
  ),
].sort((a, b) => a.localeCompare(b, 'fr'));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cyber Veille',
  description:
    'Ne laissez pas les arnaques vous surprendre. Mise à jour à 7h00, 13h00 et 18h00.',
  inLanguage: 'fr-FR',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: allArticles.length,
    itemListElement: allArticles.slice(0, 24).map((article, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: safeHttpUrl(article.url) || undefined,
      name: article.title,
      datePublished: article.publishedAt,
      publisher: sourceLabel(article),
    })),
  },
};

const hasMissingInoreaderAuthWarning = (veille.warnings || []).some((warning) =>
  String(warning || '').toLowerCase().includes('missing inoreader auth'),
);
const publicWarnings = (veille.warnings || [])
  .map((warning) => String(warning || '').trim())
  .filter(Boolean)
  .filter((warning) => !warning.toLowerCase().includes('missing inoreader auth'));
if (hasMissingInoreaderAuthWarning) {
  publicWarnings.unshift('Alimentation en direct temporairement indisponible. Affichage depuis le cache.');
}

const franceSourceRegex =
  /(france|gouv|anssi|cybermalveillance|franceinfo|francebleu|bfm|ouest-france|le parisien|la depeche|actu\.fr|numerama|clubic|zataz|le monde)/i;

function isFranceArticle(article) {
  const source = String(article?.source || '');
  const sourceLower = source.toLowerCase();
  const url = String(article?.url || '');
  if (sourceLower.includes('fuité aujourd') || sourceLower.includes('bonjourlafuite')) return true;
  if (franceSourceRegex.test(source)) return true;
  try {
    const host = new URL(url).hostname.toLowerCase();
    if (host.includes('bonjourlafuite.eu.org')) return true;
    return host.endsWith('.fr') || host.includes('france');
  } catch {
    return false;
  }
}
---

<SiteLayout
  title="Veille"
  description="Ne laissez pas les arnaques vous surprendre. Savoir, c’est déjà une protection."
  eyebrow="Veille"
  headline="Veille"
  accent="cyber"
  intro={`⚠️ Ne laissez pas les arnaques vous surprendre

Savoir, c’est déjà une protection.
Informez-vous, partagez, protégez-vous… et protégez les autres.
Mise à jour hebdomadaire lorsqu’il y a de nouvelles actualités détectées.`}
  showShare={false}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <section class="veille-controls">
    <div class="controls-card">
      <div class="rss-links">
        <a href="/flux" class="rss-button">Voir tous les flux RSS</a>
        <a href="/veille.xml" class="rss-button rss-button-secondary">S'abonner à la veille complète</a>
        <a href="/veille-sources" class="rss-button rss-button-secondary">Voir nos sources</a>
        <button id="veille-reset" type="button" class="rss-button rss-button-ghost">Réinitialiser les filtres</button>
      </div>

      <div class="filters-grid">
        <label class="field-group" for="veille-search">
          <span class="filter-label">Recherche</span>
          <input id="veille-search" type="search" class="filter-input" placeholder="Titre, source, tag…" />
        </label>

        <label class="field-group" for="veille-source">
          <span class="filter-label">Source</span>
          <select id="veille-source" class="filter-input">
            <option value="">Toutes les sources</option>
            {allSources.map((source) => <option value={source}>{source}</option>)}
          </select>
        </label>

        <label class="field-group" for="veille-tag">
          <span class="filter-label">Tag</span>
          <select id="veille-tag" class="filter-input">
            <option value="">Tous les tags</option>
            {allTags.map((tag) => <option value={tag}>{tag}</option>)}
          </select>
        </label>

        <label for="veille-new" class="filter-checkbox">
          <input id="veille-new" type="checkbox" />
          Nouveau uniquement (&lt; 72h)
        </label>
        <label for="veille-international" class="filter-checkbox">
          <input id="veille-international" type="checkbox" />
          Afficher l'international
        </label>
      </div>
    </div>

    {publicWarnings.length > 0 && <p class="warning-box">Mode dégradé partiel : {publicWarnings.join(' | ')}</p>}
  </section>

  <section class="action-strip" aria-label="Actions rapides">
    <h2>Actions rapides en cas d'arnaque</h2>
    <div class="action-strip-grid">
      <a href="https://www.cybermalveillance.gouv.fr/signalement" target="_blank" rel="noopener noreferrer nofollow">
        Signaler une arnaque
      </a>
      <a href="https://www.17cyber.gouv.fr/" target="_blank" rel="noopener noreferrer nofollow">
        Obtenir une aide immédiate (17Cyber)
      </a>
      <a href="https://www.internet-signalement.gouv.fr/PharosS1/" target="_blank" rel="noopener noreferrer nofollow">
        Signaler sur PHAROS
      </a>
    </div>
  </section>

  {
    homeSections.map((section) => {
      const visibleArticles = [...section.articles].sort(
        (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime(),
      );

      return (
      <section class="veille-section" data-section={section.key}>
        <div class="section-headline">
          <h2><a class="section-page-link" href={`/veille/${section.key}`}>{section.title}</a></h2>
          <a href={`/veille-${section.key}.xml`} class="section-rss-link" aria-label={`RSS ${section.title}`}>
            RSS
          </a>
        </div>
        <p class="section-subtitle">
          <span class="visible-count" data-visible-count>{visibleArticles.length}</span>
          <span> / </span>
          <span class="total-count" data-total-count>{visibleArticles.length}</span>
          <span> article(s) correspondant aux filtres</span>
          {!section.live && <span> • alimentation temporairement en cache</span>}
        </p>
        {section.key === 'failles' && (
          <p class="section-alert">
            Client de ce site ? Vos infos peuvent fuiter ailleurs.
            Changez vos mots de passe (surtout s’ils sont réutilisés) et utilisez-en un différent par service, avec
            une <a href="/blog/activer-la-2fa-sur-vos-comptes">double sécurité</a>.
          </p>
        )}

        {visibleArticles.length === 0 ? (
          <p class="empty-state">Aucun article disponible pour le moment.</p>
        ) : (
          <>
          <div class="veille-grid" data-section-grid>
            {visibleArticles.map((article, index) => {
              const articleTags = tagsForArticle(article, section.key);
              const articleSource = sourceLabel(article);
              const articleUrl = safeHttpUrl(article.url);
              return (
              <article
                class="veille-card"
                data-search={`${article.title} ${articleSource} ${articleTags.join(' ')}`.toLowerCase()}
                data-source={articleSource}
                data-tags={articleTags.map((tag) => tag.toLowerCase()).join(',')}
                data-published-at={article.publishedAt}
                data-is-fr={isFranceArticle(article) ? '1' : '0'}
                data-index={index}
              >
                <header class="card-head">
                  <p class="card-meta">
                    <span>{articleSource}</span>
                    <span aria-hidden="true">•</span>
                    <time datetime={article.publishedAt}>
                      {new Date(article.publishedAt).toLocaleString('fr-FR', {
                        dateStyle: 'medium',
                        timeStyle: 'short',
                      })}
                    </time>
                  </p>
                  <h3>{article.title}</h3>
                </header>

                {articleTags.length > 0 && (
                  <ul class="tags-list">
                    {articleTags.map((tag) => <li>#{tag}</li>)}
                  </ul>
                )}

                <div class="card-actions">
                  {articleUrl ? (
                    <a href={articleUrl} target="_blank" rel="noopener noreferrer nofollow">Lire la source</a>
                  ) : (
                    <span aria-label="Source indisponible">Source indisponible</span>
                  )}
                </div>
              </article>
            );
            })}
          </div>
          <div class="section-more">
            <button type="button" class="more-button" data-more-btn data-step="6">
              Afficher plus
            </button>
            <button type="button" class="less-button" data-less-btn>
              Voir moins
            </button>
          </div>
          </>
        )}
      </section>
      );
    })
  }

  <button
    id="back-to-top"
    class="back-to-top"
    aria-label="Retour en haut de page"
    aria-hidden="true"
    tabindex="-1"
  >
    <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"></path></svg>
  </button>

  <script>
    const searchInput = document.getElementById('veille-search');
    const sourceSelect = document.getElementById('veille-source');
    const tagSelect = document.getElementById('veille-tag');
    const newOnlyInput = document.getElementById('veille-new');
    const internationalInput = document.getElementById('veille-international');
    const resetButton = document.getElementById('veille-reset');
    const cards = Array.from(document.querySelectorAll('.veille-card'));
    const sectionLimits = new Map();
    const DEFAULT_VISIBLE_PER_SECTION = 6;

    const SEVENTY_TWO_HOURS_MS = 72 * 60 * 60 * 1000;

    Array.from(document.querySelectorAll('.veille-section')).forEach((section) => {
      sectionLimits.set(section, DEFAULT_VISIBLE_PER_SECTION);
    });

    function applyFilters() {
      const searchValue = (searchInput?.value || '').trim().toLowerCase();
      const sourceValue = (sourceSelect?.value || '').trim().toLowerCase();
      const tagValue = (tagSelect?.value || '').trim().toLowerCase();
      const newOnly = Boolean(newOnlyInput?.checked);
      const includeInternational = Boolean(internationalInput?.checked);
      const now = Date.now();

      const sections = Array.from(document.querySelectorAll('.veille-section'));

      sections.forEach((section) => {
        const cardsInSection = Array.from(section.querySelectorAll('.veille-card'));
        const limit = sectionLimits.get(section) ?? DEFAULT_VISIBLE_PER_SECTION;
        const sectionKey = section.getAttribute('data-section') || '';
        const bypassGeoFilter = sectionKey === 'failles' || sectionKey === 'arnaques';
        let matchingCount = 0;
        let visibleCount = 0;

        cardsInSection.forEach((card) => {
        const searchable = card.getAttribute('data-search') || '';
        const source = (card.getAttribute('data-source') || '').trim().toLowerCase();
        const tags = (card.getAttribute('data-tags') || '')
          .split(',')
          .map((tag) => tag.trim().toLowerCase())
          .filter(Boolean);
        const publishedAt = new Date(card.getAttribute('data-published-at') || '').getTime();
        const isRecent = Number.isFinite(publishedAt) ? now - publishedAt <= SEVENTY_TWO_HOURS_MS : false;
        const isFrance = card.getAttribute('data-is-fr') === '1';

        const matchesFilters =
          (!searchValue || searchable.includes(searchValue)) &&
          (!sourceValue || source === sourceValue) &&
          (!tagValue || tags.includes(tagValue)) &&
          (!newOnly || isRecent) &&
          (bypassGeoFilter || includeInternational || isFrance);

          if (matchesFilters) {
            matchingCount += 1;
          }

          const visible = matchesFilters && matchingCount <= limit;
          card.hidden = !visible;
          if (visible) {
            visibleCount += 1;
          }
        });

        const countNode = section.querySelector('[data-visible-count]');
        const totalNode = section.querySelector('[data-total-count]');
        const moreButton = section.querySelector('[data-more-btn]');
        const lessButton = section.querySelector('[data-less-btn]');

        if (countNode) {
          countNode.textContent = String(visibleCount);
        }
        if (totalNode) {
          totalNode.textContent = String(matchingCount);
        }
        if (moreButton instanceof HTMLButtonElement) {
          const canShowMore = matchingCount > visibleCount;
          moreButton.hidden = !canShowMore;
          moreButton.disabled = !canShowMore;
        }
        if (lessButton instanceof HTMLButtonElement) {
          const canShowLess = limit > DEFAULT_VISIBLE_PER_SECTION && matchingCount > DEFAULT_VISIBLE_PER_SECTION;
          lessButton.hidden = !canShowLess;
          lessButton.disabled = !canShowLess;
        }
      });
    }

    searchInput?.addEventListener('input', applyFilters);
    sourceSelect?.addEventListener('change', applyFilters);
    tagSelect?.addEventListener('change', applyFilters);
    newOnlyInput?.addEventListener('change', applyFilters);
    internationalInput?.addEventListener('change', applyFilters);
    resetButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (sourceSelect) sourceSelect.value = '';
      if (tagSelect) tagSelect.value = '';
      if (newOnlyInput) newOnlyInput.checked = false;
      if (internationalInput) internationalInput.checked = false;
      Array.from(document.querySelectorAll('.veille-section')).forEach((section) => {
        sectionLimits.set(section, DEFAULT_VISIBLE_PER_SECTION);
      });
      applyFilters();
    });

    Array.from(document.querySelectorAll('[data-more-btn]')).forEach((button) => {
      button.addEventListener('click', () => {
        const section = button.closest('.veille-section');
        if (!section) return;
        const currentLimit = sectionLimits.get(section) ?? DEFAULT_VISIBLE_PER_SECTION;
        const step = Number(button.getAttribute('data-step') || 6);
        sectionLimits.set(section, currentLimit + step);
        applyFilters();
      });
    });
    Array.from(document.querySelectorAll('[data-less-btn]')).forEach((button) => {
      button.addEventListener('click', () => {
        const section = button.closest('.veille-section');
        if (!section) return;
        sectionLimits.set(section, DEFAULT_VISIBLE_PER_SECTION);
        applyFilters();
      });
    });
    applyFilters();

    const backBtn = document.getElementById('back-to-top');
    const syncBackToTopVisibility = () => {
      if (!(backBtn instanceof HTMLButtonElement)) return;
      const shouldShow = window.scrollY > 400;
      backBtn.classList.toggle('visible', shouldShow);
      backBtn.setAttribute('aria-hidden', String(!shouldShow));
      backBtn.tabIndex = shouldShow ? 0 : -1;
    };

    syncBackToTopVisibility();
    window.addEventListener('scroll', syncBackToTopVisibility);
    backBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>
</SiteLayout>

<style>
  :global(.hero-section .hero-content) {
    width: min(100%, 1320px);
    text-align: left;
  }

  :global(.hero-section .hero-title) {
    max-width: 100%;
  }

  :global(.hero-section .hero-desc) {
    max-width: 100%;
    margin-left: 0;
    margin-right: 0;
    white-space: pre-line;
    line-height: 1.65;
  }

  .veille-controls {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .controls-card {
    border: 1px solid var(--border-color);
    border-radius: 18px;
    background: color-mix(in srgb, var(--bg-card) 85%, transparent);
    padding: 0.85rem;
    display: grid;
    gap: 0.75rem;
  }

  .rss-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .rss-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: var(--brand-orange);
    color: #0b1120;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
  }

  .rss-button-secondary {
    background: transparent;
    color: var(--text-main);
    border: 1px solid var(--border-color);
  }

  .rss-button-ghost {
    background: transparent;
    color: var(--text-muted);
    border: 1px dashed var(--border-color);
    cursor: pointer;
    font: inherit;
  }

  .filters-grid {
    display: grid;
    gap: 0.55rem;
    grid-template-columns: minmax(220px, 1.4fr) minmax(300px, 1.2fr) minmax(190px, 0.9fr);
    align-items: end;
  }

  .field-group {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .filter-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-muted);
  }

  .filter-input {
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--bg-card);
    color: var(--text-main);
    min-height: 40px;
    padding: 0.45rem 0.7rem;
    font: inherit;
    width: 100%;
  }

  #veille-source {
    min-width: 280px;
  }

  .filter-input:hover {
    border-color: color-mix(in srgb, var(--brand-green) 45%, var(--border-color));
  }

  .filter-checkbox {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    gap: 0.45rem;
    white-space: nowrap;
    font-size: 0.84rem;
    color: var(--text-muted);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.45rem 0.7rem;
    background: var(--bg-card);
    min-width: 0;
  }

  .filter-checkbox input {
    width: 16px;
    height: 16px;
  }

  .warning-box {
    margin: 0;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    background: rgba(249, 115, 22, 0.14);
    border: 1px solid rgba(249, 115, 22, 0.4);
  }

  .action-strip {
    margin: 1.25rem 0 1.75rem;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1rem;
    background: color-mix(in srgb, var(--bg-card) 88%, transparent);
    display: grid;
    gap: 0.8rem;
  }

  .action-strip h2 {
    margin: 0;
    font-size: 1rem;
  }

  .action-strip-grid {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  }

  .action-strip-grid a {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    color: var(--text-main);
    text-decoration: none;
    padding: 0.45rem 0.75rem;
    text-align: center;
    font-weight: 600;
  }

  .action-strip-grid a:hover {
    border-color: var(--brand-green);
    color: var(--brand-green);
  }

  .veille-section + .veille-section {
    margin-top: 2rem;
  }

  .veille-section {
    border: 1px solid var(--border-color);
    border-radius: 18px;
    padding: 1rem;
    background:
      radial-gradient(120% 160% at 12% 0%, color-mix(in srgb, var(--section-accent) 18%, transparent), transparent 60%),
      color-mix(in srgb, var(--bg-card) 88%, transparent);
    --section-accent: var(--brand-green);
  }

  .veille-section[data-section='arnaques'] {
    --section-accent: #f97316;
  }

  .veille-section[data-section='failles'] {
    --section-accent: #38bdf8;
  }

  .veille-section[data-section='cyber'] {
    --section-accent: #2dd4bf;
  }

  .veille-section[data-section='associations'] {
    --section-accent: #a3e635;
  }

  .section-headline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .section-headline h2 {
    margin: 0;
  }

  .section-page-link {
    color: var(--section-accent);
    text-decoration: none;
  }

  .section-page-link:hover {
    filter: brightness(1.1);
  }

  .section-rss-link {
    border: 1px solid color-mix(in srgb, var(--section-accent) 45%, var(--border-color));
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    color: var(--section-accent);
    text-decoration: none;
    font-size: 0.86rem;
  }

  .section-rss-link:hover {
    border-color: var(--section-accent);
  }

  .section-subtitle {
    margin: 0.4rem 0 1rem;
    color: var(--text-muted);
  }

  .section-alert {
    margin: -0.2rem 0 1rem;
    color: var(--text-main);
  }

