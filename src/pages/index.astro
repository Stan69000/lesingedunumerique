---
import { getCollection } from 'astro:content';
import MaintenanceContent from '../components/MaintenanceContent.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { siteSettings } from '../config/site';
import '../styles/global.css';

const posts = await getCollection('blog');
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, 'fr'),
);
const beginnerTag = allTags.find((tag) => tag.toLowerCase().includes('debut'));
const intermediateTag = allTags.find((tag) => tag.toLowerCase().includes('inter'));
const advancedTag = allTags.find((tag) => tag.toLowerCase().includes('avanc'));
const levelTags = [
  { label: 'Débutant', emoji: '🌱', tag: beginnerTag },
  { label: 'Intermédiaire', emoji: '🧭', tag: intermediateTag },
  { label: 'Avancé', emoji: '⚡', tag: advancedTag },
];
const canonicalUrl = new URL('/', siteSettings.siteUrl).toString();
const pageTitle = 'Le Singe Du Numérique | Inclusion numérique et appui aux associations';
const pageDescription =
  "Association pour la démocratisation du numérique, la cybersécurité du quotidien, les logiciels libres et l'accompagnement des associations locales.";
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteSettings.siteName,
  url: siteSettings.siteUrl,
  logo: `${siteSettings.siteUrl}/logo.svg`,
  telephone: '+33771680601',
  areaServed: 'Fleurieux-sur-l’Arbresle et environs',
  sameAs: [],
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteSettings.siteName,
  url: siteSettings.siteUrl,
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteSettings.siteUrl}/blog?search={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteSettings.siteUrl}/logo.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  </head>

  <body>
    {
      siteSettings.maintenanceMode ? (
        <MaintenanceContent />
      ) : (
        <>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>

    <nav class="navbar" aria-label="Navigation principale">
      <div class="container nav-container">
        <a href="/" class="brand-logo" aria-label="Le Singe Du Numérique, accueil">
          <img src="/logo.svg" alt="" aria-hidden="true" class="navbar-logo" />
          <span class="brand-text">Le Singe Du Numérique</span>
        </a>

        <div class="nav-right">
          <ul class="nav-links">
            <li><a href="/projets" class="nav-item">Projets</a></li>
            <li><a href="/asso" class="nav-item">L’association</a></li>
            <li><a href="/evenements" class="nav-item">Événements</a></li>
            <li><a href="/adhesion" class="nav-item">Rejoindre</a></li>
            <li><a href="/contact" class="nav-item">Contact</a></li>
            <li><a href="/blog" class="nav-item">Blog</a></li>
          </ul>
          <button
            id="theme-toggle"
            class="theme-btn"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            <span class="icon-light">☀️</span>
            <span class="icon-dark">🌙</span>
          </button>
        </div>

        <button
          class="burger-btn"
          id="burger-btn"
          aria-label="Ouvrir le menu principal"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div
        class="mobile-menu"
        id="mobile-menu"
        aria-label="Navigation mobile"
        aria-hidden="true"
        inert
        hidden
      >
        <a href="/projets" class="mobile-item">Projets</a>
        <a href="/asso" class="mobile-item">L’association</a>
        <a href="/evenements" class="mobile-item">Événements</a>
        <a href="/adhesion" class="mobile-item">Rejoindre</a>
        <a href="/contact" class="mobile-item">Contact</a>
        <a href="/blog" class="mobile-item">Blog</a>
        <div class="mobile-theme-toggle">
          <span>Changer le thème</span>
          <button
            id="mobile-theme-btn"
            class="theme-btn-small"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            🌙
          </button>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <section class="hero-section">
        <div class="glow-bg glow-green"></div>
        <div class="glow-bg glow-orange"></div>

        <div class="container hero-content">
          <div class="hero-logo-wrapper" aria-hidden="true">
            <span class="hero-logo-aura hero-logo-aura-primary"></span>
            <span class="hero-logo-aura hero-logo-aura-secondary"></span>
            <img src="/logo.svg" alt="Le Singe Du Numérique" class="hero-logo" />
          </div>

          <p class="eyebrow">Inclusion numérique et transformation associative</p>
          <h1 class="hero-title">
            Le numérique plus <span class="gradient-text">accessible</span> pour tous, plus utile
            pour les associations
          </h1>

          <p class="hero-desc">
            Le Singe Du Numérique agit pour la démocratisation et l&apos;inclusion numérique, et
            accompagne aussi les associations locales dans leurs usages, leurs outils et leur
            transformation numérique.
          </p>

          <form class="search-wrapper" action="/blog" method="get">
            <label class="sr-only" for="home-search">Recherche dans le blog</label>
            <div class="search-bar">
              <span class="search-icon" aria-hidden="true">
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
              </span>
              <input
                id="home-search"
                type="search"
                name="search"
                placeholder="Rechercher une ressource, un article ou un sujet..."
                class="search-input"
              />
              <button type="submit" class="search-submit">Rechercher</button>
            </div>

            <div class="search-meta">
              <a href="/blog" class="filter-tag">
                <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                <span>Filtrer les articles du blog</span>
              </a>
              <span class="divider">|</span>
              <span class="tag-count">{allTags.length} tags disponibles</span>
            </div>

            <div class="explore-link">
              <a href="/blog">Voir tous les tags du blog →</a>
            </div>
          </form>

          <div class="quick-actions">
            {levelTags
              .filter((level) => level.tag)
              .map((level) => (
                <a href={`/blog?tag=${encodeURIComponent(level.tag)}`} class="quick-tag">
                  {level.emoji} {level.label}
                </a>
              ))}
          </div>
        </div>
      </section>

      <section id="missions" class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Deux axes, une même <span class="text-accent">ambition</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="grid">
            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">👥</span>
              </div>
              <div class="card-content">
                <h3>Pour tous les publics</h3>
                <p>
                  Ateliers pratiques, accompagnement aux usages, cybersécurité du quotidien et aide
                  à la prise en main des outils numériques.
                </p>
                <div class="card-tags"><span>Inclusion</span><span>Pédagogie</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">🏛️</span>
              </div>
              <div class="card-content">
                <h3>Pour les associations locales</h3>
                <p>
                  Conseil, assistance technique, choix d&apos;outils, logiciels libres et
                  automatisation pour soutenir la transformation numérique du tissu associatif local.
                </p>
                <div class="card-tags"><span>Conseil</span><span>Terrain</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">🌍</span>
              </div>
              <div class="card-content">
                <h3>Une approche accessible et locale</h3>
                <p>
                  L&apos;association adapte ses actions chaque année selon ses moyens et les besoins
                  locaux, dans une démarche pédagogique, éthique et concrète.
                </p>
                <div class="card-tags"><span>Éthique</span><span>Libre</span></div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="content-section content-section-alt">
        <div class="container">
          <div class="section-header">
            <h2>Ce que nous <span class="text-accent">faisons</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="grid">
            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">🛡️</span>
              </div>
              <div class="card-content">
                <h3>Cybersécurité du quotidien</h3>
                <p>Protection des données, bons réflexes et usages plus sûrs du web, de l’ordinateur et du smartphone.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">💻</span>
              </div>
              <div class="card-content">
                <h3>Matériel et autonomie numérique</h3>
                <p>Aide au choix, à l’utilisation et à la prise en main de matériel informatique selon les besoins et les moyens.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">♻️</span>
              </div>
              <div class="card-content">
                <h3>Logiciels libres et solutions éthiques</h3>
                <p>Promotion d’outils plus respectueux, durables et adaptés aux personnes comme aux structures associatives.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">🧰</span>
              </div>
              <div class="card-content">
                <h3>Conseil aux associations</h3>
                <p>Appui technique, mise en place d’outils numériques et accompagnement des usages pour la vie associative.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">⚙️</span>
              </div>
              <div class="card-content">
                <h3>Scripts et automatisation</h3>
                <p>Développement de solutions simples pour faire gagner du temps aux associations et alléger certaines tâches répétitives.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">🤝</span>
              </div>
              <div class="card-content">
                <h3>Événements et entraide</h3>
                <p>Tout événement favorisant le partage de connaissances, l’entraide et l’apprentissage dans une approche accessible.</p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Ressources, veille et <span class="text-accent">outils</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="grid">
            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">📝</span>
              </div>
              <div class="card-content">
                <h3>Articles</h3>
                <p>Guides, conseils pratiques, cybersécurité, protection des données et usages du numérique au quotidien.</p>
                <div class="card-tags"><span>Conseils</span><span>Usages</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">🔎</span>
              </div>
              <div class="card-content">
                <h3>Veille</h3>
                <p>Sélection de ressources, médias, podcasts, lectures et contenus utiles à suivre pour rester informé sans se perdre.</p>
                <div class="card-tags"><span>Curation</span><span>Ressources</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">🧪</span>
              </div>
              <div class="card-content">
                <h3>Technos</h3>
                <p>Logiciels libres, outils éthiques, automatisation et solutions techniques utiles pour les particuliers comme pour les associations.</p>
                <div class="card-tags"><span>Libre</span><span>Outils</span></div>
              </div>
            </article>
          </div>

          <div class="cta-strip">
            <p>
              Les éventuels bénéfices tirés de prestations de service sont intégralement réinvestis
              dans la réalisation de l’objet social.
            </p>
            <ul class="cta-row">
              <li><a href="/asso" class="cta-link">Découvrir l’association</a></li>
              <li><a href="/projets" class="cta-link">Voir nos actions</a></li>
              <li><a href="/blog" class="cta-link">Lire les ressources</a></li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <section class="content-section">
      <div class="container">
        <ShareButtons title="Le Singe Du Numérique" label="Partager le site" />
      </div>
    </section>

    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-main">
          <div class="footer-brand">
            <img src="/logo.svg" alt="" aria-hidden="true" class="footer-logo" />
            <span>Le Singe Du Numérique</span>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Menu</span>
            <ul class="footer-line-content footer-links">
              <li><a href="/projets">Projets</a></li>
              <li><a href="/asso">L’association</a></li>
              <li><a href="/evenements">Événements</a></li>
              <li><a href="/adhesion">Rejoindre</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/mentions-legales">Mentions légales</a></li>
            </ul>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Statut</span>
            <div class="footer-line-content">
              <a
                id="service-status-link"
                class="service-status"
                href="https://le-singe-du-numerique.betteruptime.com/"
                target="_blank"
                rel="noopener noreferrer"
                aria-live="polite"
              >
                <span id="service-status-dot" class="status-dot status-checking" aria-hidden="true"></span>
                <span id="service-status-text">Statut : vérification...</span>
              </a>
              <span class="footer-separator">•</span>
              <a href="/accessibilite">Accessibilité : non conforme</a>
            </div>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Crédit</span>
            <div class="footer-line-content">
              <span class="footer-credit">Fait avec ❤️ entre père et fils - Stan et Mikaël BOUCHET</span>
            </div>
          </div>
          <div class="footer-line">
            <span class="footer-line-label">Réseaux</span>
            <ul class="footer-line-content footer-socials">
              <li>
                <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                  <span>LinkedIn Stan</span>
                </a>
              </li>
              <li>
                <a href="https://www.linkedin.com/in/mikael-bch/" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                  <span>LinkedIn Mikaël</span>
                </a>
              </li>
              <li>
                <a href="https://github.com/Stan69000/lesingedunumerique" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.35-3.87-1.35-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.27 1.17-3.07-.12-.29-.5-1.47.11-3.05 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.13-1.17 3.13-1.17.62 1.58.24 2.76.12 3.05.73.8 1.17 1.82 1.17 3.07 0 4.41-2.69 5.37-5.25 5.66.41.36.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
                  <span>GitHub</span>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <button id="back-to-top" class="back-to-top" aria-label="Retour en haut de page">
      <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"></path></svg>
    </button>

    <script>
      const themeBtn = document.getElementById('theme-toggle');
      const mobileThemeBtn = document.getElementById('mobile-theme-btn');
      const body = document.body;
      let lastFocusedElement = null;

      function syncThemeControls() {
        const isLight = body.classList.contains('light-mode');
        const icon = isLight ? '☀️' : '🌙';
        const actionLabel = isLight ? 'Activer le thème sombre' : 'Activer le thème clair';

        if (themeBtn) {
          themeBtn.innerHTML = isLight
            ? '<span class="icon-light">☀️</span>'
            : '<span class="icon-dark">🌙</span>';
          themeBtn.setAttribute('aria-label', actionLabel);
          themeBtn.setAttribute('aria-pressed', String(isLight));
        }

        if (mobileThemeBtn) {
          mobileThemeBtn.textContent = icon;
          mobileThemeBtn.setAttribute('aria-label', actionLabel);
          mobileThemeBtn.setAttribute('aria-pressed', String(isLight));
        }
      }

      if (localStorage.getItem('theme') === 'light') {
        body.classList.add('light-mode');
      }

      syncThemeControls();

      function toggleTheme() {
        body.classList.toggle('light-mode');
        const isLight = body.classList.contains('light-mode');
        syncThemeControls();
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
      }

      if (themeBtn) themeBtn.addEventListener('click', toggleTheme);
      if (mobileThemeBtn) mobileThemeBtn.addEventListener('click', toggleTheme);

      const burgerBtn = document.getElementById('burger-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      if (burgerBtn && mobileMenu) {
        const mobileFocusableSelector =
          'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

        const getMenuFocusableElements = () =>
          Array.from(mobileMenu.querySelectorAll(mobileFocusableSelector)).filter(
            (element) => !element.hasAttribute('hidden'),
          );

        const setMenuState = (isOpen) => {
          mobileMenu.classList.toggle('active', isOpen);
          burgerBtn.classList.toggle('active', isOpen);
          burgerBtn.setAttribute('aria-expanded', String(isOpen));
          burgerBtn.setAttribute(
            'aria-label',
            isOpen ? 'Fermer le menu principal' : 'Ouvrir le menu principal',
          );
          mobileMenu.hidden = !isOpen;
          mobileMenu.setAttribute('aria-hidden', String(!isOpen));
          if (isOpen) {
            mobileMenu.removeAttribute('inert');
          } else {
            mobileMenu.setAttribute('inert', '');
          }
          document.body.style.overflow = isOpen ? 'hidden' : '';

          const navRight = document.querySelector('.nav-right');
          const mainContent = document.getElementById('main-content');
          const footer = document.querySelector('.footer');

          [navRight, mainContent, footer].forEach((element) => {
            if (!element) return;
            if (isOpen) {
              element.setAttribute('inert', '');
            } else {
              element.removeAttribute('inert');
            }
          });

          if (isOpen) {
            lastFocusedElement = document.activeElement;
            window.setTimeout(() => {
              getMenuFocusableElements()[0]?.focus();
            }, 0);
          } else if (lastFocusedElement instanceof HTMLElement) {
            lastFocusedElement.focus();
            lastFocusedElement = null;
          }
        };

        setMenuState(false);

        burgerBtn.addEventListener('click', () => {
          const isOpen = burgerBtn.getAttribute('aria-expanded') !== 'true';
          setMenuState(isOpen);
        });

        document.querySelectorAll('.mobile-item').forEach((item) => {
          item.addEventListener('click', () => {
            setMenuState(false);
          });
        });

        document.addEventListener('keydown', (event) => {
          const menuIsOpen = burgerBtn.getAttribute('aria-expanded') === 'true';

          if (event.key === 'Escape' && menuIsOpen) {
            setMenuState(false);
            return;
          }

          if (event.key === 'Tab' && menuIsOpen) {
            const focusableElements = getMenuFocusableElements();
            if (focusableElements.length === 0) return;

            const firstElement = focusableElements[0];
            const lastElement = focusableElements[focusableElements.length - 1];
            const activeElement = document.activeElement;

            if (event.shiftKey && activeElement === firstElement) {
              event.preventDefault();
              lastElement.focus();
            } else if (!event.shiftKey && activeElement === lastElement) {
              event.preventDefault();
              firstElement.focus();
            }
          }
        });
      }

      const serviceStatusDot = document.getElementById('service-status-dot');
      const serviceStatusText = document.getElementById('service-status-text');

      function setServiceStatus(state) {
        if (!serviceStatusDot || !serviceStatusText) return;

        serviceStatusDot.classList.remove('status-checking', 'status-ok', 'status-ko', 'status-local');

        if (state === 'ok') {
          serviceStatusDot.classList.add('status-ok');
          serviceStatusText.textContent = 'Statut : opérationnel';
          return;
        }

        if (state === 'ko') {
          serviceStatusDot.classList.add('status-ko');
          serviceStatusText.textContent = 'Statut : incident détecté';
          return;
        }

        if (state === 'local') {
          serviceStatusDot.classList.add('status-local');
          serviceStatusText.textContent = 'Statut : vérif en production';
          return;
        }

        serviceStatusDot.classList.add('status-checking');
        serviceStatusText.textContent = 'Statut : vérification...';
      }

      async function refreshServiceStatus() {
        if (
          location.hostname === 'localhost'
          || location.hostname === '127.0.0.1'
          || location.hostname.endsWith('.local')
        ) {
          setServiceStatus('local');
          return;
        }

        setServiceStatus('checking');
        try {
          const response = await fetch('/contact-health.php', {
            method: 'GET',
            cache: 'no-store',
            credentials: 'same-origin',
          });
          const body = (await response.text()).trim();
          if (response.ok && body === 'OK') {
            setServiceStatus('ok');
            return;
          }
        } catch (error) {}
        setServiceStatus('ko');
      }

      if (serviceStatusDot && serviceStatusText) {
        refreshServiceStatus();
        window.setInterval(refreshServiceStatus, 60000);
      }

      const backBtn = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) backBtn.classList.add('visible');
        else backBtn.classList.remove('visible');
      });
      backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    </script>
        </>
      )
    }
  </body>
</html>

