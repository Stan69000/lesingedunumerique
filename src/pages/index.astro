---
import { getCollection } from 'astro:content';
import MaintenanceContent from '../components/MaintenanceContent.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { siteSettings } from '../config/site';
import '../styles/global.css';
import '../styles/home.css';

const posts = await getCollection('blog');
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, 'fr'),
);
const beginnerTag = allTags.find((tag) => tag.toLowerCase().includes('debut'));
const intermediateTag = allTags.find((tag) => tag.toLowerCase().includes('inter'));
const advancedTag = allTags.find((tag) => tag.toLowerCase().includes('avanc'));
const levelTags = [
  { label: 'Débutant', emoji: '🌱', tag: beginnerTag },
  { label: 'Intermédiaire', emoji: '🧭', tag: intermediateTag },
  { label: 'Avancé', emoji: '⚡', tag: advancedTag },
];
const canonicalUrl = new URL('/', siteSettings.siteUrl).toString();
const pageTitle = 'Inclusion numérique pour tous | Le Singe Du Numérique';
const pageDescription =
  'Association d’inclusion numérique : cybersécurité, logiciels libres et accompagnement des associations locales. Découvrez nos ressources et ateliers pratiques.';
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteSettings.siteName,
  url: siteSettings.siteUrl,
  logo: `${siteSettings.siteUrl}/logo.svg`,
  telephone: '+33771680601',
  areaServed: 'Fleurieux-sur-l’Arbresle et environs',
  sameAs: [],
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteSettings.siteName,
  url: siteSettings.siteUrl,
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteSettings.siteUrl}/blog?search={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteSettings.siteUrl}/logo.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  </head>

  <body>
    {
      siteSettings.maintenanceMode ? (
        <MaintenanceContent />
      ) : (
        <>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>

    <header>
    <nav class="navbar" aria-label="Navigation principale">
      <div class="container nav-container">
        <a href="/" class="brand-logo" aria-label="Le Singe Du Numérique, accueil">
          <img src="/logo.svg" alt="" aria-hidden="true" class="navbar-logo" />
          <span class="brand-text">Le Singe Du Numérique</span>
        </a>

        <div class="nav-right">
          <ul class="nav-links">
            <li><a href="/projets" class="nav-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a></li>
            <li><a href="/asso" class="nav-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a></li>
            <li><a href="/evenements" class="nav-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a></li>
            <li><a href="/adhesion" class="nav-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a></li>
            <li><a href="/contact" class="nav-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a></li>
            <li><a href="/blog" class="nav-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a></li>
            <li><a href="/veille" class="nav-item" aria-current={currentPath.startsWith('/veille') ? 'page' : undefined}>Actu</a></li>
          </ul>
          <a href="/flux" class="rss-nav-link" aria-current={currentPath === '/flux' ? 'page' : undefined} aria-label="Acceder aux flux RSS">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 17.82a2.18 2.18 0 1 1 0-4.36 2.18 2.18 0 0 1 0 4.36ZM4 4v3.27c7.03 0 12.73 5.7 12.73 12.73H20C20 11.16 12.84 4 4 4Zm0 6.54v3.27A6.2 6.2 0 0 1 10.2 20h3.27A9.47 9.47 0 0 0 4 10.54Z"/></svg>
            <span>RSS</span>
          </a>
          <button
            id="theme-toggle"
            class="theme-btn"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            <span class="icon-light">☀️</span>
            <span class="icon-dark">🌙</span>
          </button>
        </div>

        <button
          class="burger-btn"
          id="burger-btn"
          aria-label="Ouvrir le menu principal"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div
        class="mobile-menu"
        id="mobile-menu"
        aria-label="Navigation mobile"
        aria-hidden="true"
        inert
        hidden
      >
        <a href="/projets" class="mobile-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
        <a href="/asso" class="mobile-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a>
        <a href="/evenements" class="mobile-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
        <a href="/adhesion" class="mobile-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a>
        <a href="/contact" class="mobile-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a>
        <a href="/blog" class="mobile-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
        <a href="/veille" class="mobile-item" aria-current={currentPath.startsWith('/veille') ? 'page' : undefined}>Actu</a>
        <a href="/flux" class="mobile-item" aria-current={currentPath === '/flux' ? 'page' : undefined}>Flux RSS</a>
        <div class="mobile-theme-toggle">
          <span>Changer le thème</span>
          <button
            id="mobile-theme-btn"
            class="theme-btn-small"
            type="button"
            aria-label="Activer le thème clair"
            aria-pressed="false"
          >
            🌙
          </button>
        </div>
      </div>
    </nav>
    </header>

    <main id="main-content">
      <section class="hero-section">
        <div class="glow-bg glow-green"></div>
        <div class="glow-bg glow-orange"></div>

        <div class="container hero-content">
          <div class="hero-logo-wrapper" aria-hidden="true">
            <span class="hero-logo-aura hero-logo-aura-primary"></span>
            <span class="hero-logo-aura hero-logo-aura-secondary"></span>
            <img src="/logo.svg" alt="Le Singe Du Numérique" class="hero-logo" />
          </div>

          <p class="eyebrow">Inclusion numérique et transformation associative</p>
          <h1 class="hero-title">
            Le numérique plus <span class="gradient-text">accessible</span> pour tous, plus utile
            pour les associations
          </h1>

          <p class="hero-desc">
            Le Singe Du Numérique agit pour la démocratisation et l&apos;inclusion numérique, et
            accompagne aussi les associations locales dans leurs usages, leurs outils et leur
            transformation numérique.
          </p>

          <form class="search-wrapper" action="/blog" method="get" role="search" aria-label="Recherche dans les articles du blog">
            <label class="sr-only" for="home-search">Recherche dans les articles du blog</label>
            <div class="search-bar">
              <span class="search-icon" aria-hidden="true">
                <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
              </span>
              <input
                id="home-search"
                type="search"
                name="search"
                placeholder="Rechercher une ressource, un article ou un sujet..."
                class="search-input"
                autocomplete="off"
                aria-describedby="home-search-help home-search-error"
              />
              <button type="submit" class="search-submit" aria-label="Rechercher dans le blog">Rechercher</button>
            </div>
            <p id="home-search-help" class="search-assist">
              Astuce : saisis au moins 2 caractères (ex. « cybersécurité », « bénévolat », « atelier »).
            </p>
            <p id="home-search-error" class="search-error" hidden aria-live="polite"></p>

            <div class="search-meta">
              <button type="submit" class="filter-tag">
                <svg aria-hidden="true" focusable="false" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                <span>Filtrer les articles du blog</span>
              </button>
              <span class="tag-count">{allTags.length} tags disponibles</span>
            </div>

            <div class="explore-link">
              <a href="#niveaux-blog">Voir les niveaux de lecture ↓</a>
            </div>
          </form>

          <div class="quick-actions" id="niveaux-blog">
            {levelTags
              .filter((level) => level.tag)
              .map((level) => (
                <a href={`/blog?tag=${encodeURIComponent(level.tag)}`} class="quick-tag">
                  {level.emoji} {level.label}
                </a>
              ))}
          </div>
        </div>
      </section>

      <section id="missions" class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Deux axes, une même <span class="text-accent">ambition</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="grid">
            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">👥</span>
              </div>
              <div class="card-content">
                <h3>Pour tous les publics</h3>
                <p>
                  Ateliers pratiques, accompagnement aux usages, cybersécurité du quotidien et aide
                  à la prise en main des outils numériques.
                </p>
                <div class="card-tags"><span>Inclusion</span><span>Pédagogie</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">🏛️</span>
              </div>
              <div class="card-content">
                <h3>Pour les associations locales</h3>
                <p>
                  Conseil, assistance technique, choix d&apos;outils, logiciels libres et
                  automatisation pour soutenir la transformation numérique du tissu associatif local.
                </p>
                <div class="card-tags"><span>Conseil</span><span>Terrain</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">🌍</span>
              </div>
              <div class="card-content">
                <h3>Une approche accessible et locale</h3>
                <p>
                  L&apos;association adapte ses actions chaque année selon ses moyens et les besoins
                  locaux, dans une démarche pédagogique, éthique et concrète.
                </p>
                <div class="card-tags"><span>Éthique</span><span>Libre</span></div>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="content-section content-section-alt">
        <div class="container">
          <div class="section-header">
            <h2>Ce que nous <span class="text-accent">faisons</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="grid">
            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">🛡️</span>
              </div>
              <div class="card-content">
                <h3>Cybersécurité du quotidien</h3>
                <p>Protection des données, bons réflexes et usages plus sûrs du web, de l’ordinateur et du smartphone.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">💻</span>
              </div>
              <div class="card-content">
                <h3>Matériel et autonomie numérique</h3>
                <p>Aide au choix, à l’utilisation et à la prise en main de matériel informatique selon les besoins et les moyens.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">♻️</span>
              </div>
              <div class="card-content">
                <h3>Logiciels libres et solutions éthiques</h3>
                <p>Promotion d’outils plus respectueux, durables et adaptés aux personnes comme aux structures associatives.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">🧰</span>
              </div>
              <div class="card-content">
                <h3>Conseil aux associations</h3>
                <p>Appui technique, mise en place d’outils numériques et accompagnement des usages pour la vie associative.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">⚙️</span>
              </div>
              <div class="card-content">
                <h3>Scripts et automatisation</h3>
                <p>Développement de solutions simples pour faire gagner du temps aux associations et alléger certaines tâches répétitives.</p>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">🤝</span>
              </div>
              <div class="card-content">
                <h3>Événements et entraide</h3>
                <p>Tout événement favorisant le partage de connaissances, l’entraide et l’apprentissage dans une approche accessible.</p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Notre action <span class="text-accent">associative</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="association-copy">
            <article class="association-block">
              <h3>Pour qui ?</h3>
              <p>
                L’association agit pour les habitants, les bénévoles et les structures locales qui
                ont besoin d’un appui numérique. Notre objectif est l’inclusion numérique: rendre
                les usages plus simples, plus sûrs et plus autonomes.
              </p>
            </article>

            <article class="association-block">
              <h3>Comment intervenons-nous ?</h3>
              <p>
                Nos actions se construisent selon les besoins du territoire: ateliers, entraide,
                sensibilisation, appui technique et orientation vers des ressources adaptées. Nous
                privilégions des outils accessibles, durables et compréhensibles par tous.
              </p>
            </article>

            <article class="association-block">
              <h3>Ancrage local</h3>
              <p>
                Nous intervenons principalement à Fleurieux-sur-l’Arbresle et dans les communes
                voisines, en présentiel ou à distance selon les possibilités de l’association.
              </p>
            </article>

            <article class="association-block">
              <h3>Exemples d’actions</h3>
              <p>
                Sensibilisation à la cybersécurité du quotidien, prise en main d’outils numériques,
                découverte des logiciels libres, amélioration de l’organisation numérique
                associative, et partage de bonnes pratiques.
              </p>
            </article>
          </div>

          <div class="association-faq">
            <h3>Questions fréquentes</h3>
            <ul class="association-faq-list">
              <li>
                <strong>Faut-il être expert&nbsp;?</strong> Non, nos actions sont ouvertes à tous
                les niveaux.
              </li>
              <li>
                <strong>Est-ce réservé aux associations&nbsp;?</strong> Non, l’association agit
                aussi pour les particuliers.
              </li>
              <li>
                <strong>Comment participer&nbsp;?</strong> Via la page Contact ou en rejoignant nos
                actions locales.
              </li>
            </ul>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="container">
          <div class="section-header">
            <h2>Ressources, veille et <span class="text-accent">outils</span></h2>
            <div class="line-deco"></div>
          </div>

          <div class="grid">
            <article class="card">
              <div class="card-header card-green">
                <span class="card-icon">📝</span>
              </div>
              <div class="card-content">
                <h3>Articles</h3>
                <p>Guides, conseils pratiques, cybersécurité, protection des données et usages du numérique au quotidien.</p>
                <div class="card-tags"><span>Conseils</span><span>Usages</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-orange">
                <span class="card-icon">🔎</span>
              </div>
              <div class="card-content">
                <h3>Veille</h3>
                <p>Sélection de ressources, médias, podcasts, lectures et contenus utiles à suivre pour rester informé sans se perdre.</p>
                <div class="card-tags"><span>Curation</span><span>Ressources</span></div>
              </div>
            </article>

            <article class="card">
              <div class="card-header card-blue">
                <span class="card-icon">🧪</span>
              </div>
              <div class="card-content">
                <h3>Technos</h3>
                <p>Logiciels libres, outils éthiques, automatisation et solutions techniques utiles pour les particuliers comme pour les associations.</p>
                <div class="card-tags"><span>Libre</span><span>Outils</span></div>
              </div>
            </article>
          </div>

          <div class="cta-strip">
            <p>
              Les éventuels bénéfices tirés de prestations de service sont intégralement réinvestis
              dans la réalisation de l’objet social.
            </p>
            <ul class="cta-row">
              <li><a href="/asso" class="cta-link">Découvrir l’association</a></li>
              <li><a href="/projets" class="cta-link">Voir nos actions</a></li>
              <li><a href="/blog" class="cta-link">Lire les ressources</a></li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <section class="content-section">
      <div class="container">
        <ShareButtons title="Le Singe Du Numérique" label="Partager le site" />
      </div>
    </section>

    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-main">
          <div class="footer-brand">
            <img src="/logo.svg" alt="" aria-hidden="true" class="footer-logo" />
            <span>Le Singe Du Numérique</span>
          </div>
          <div class="footer-line">
            <h2 class="footer-line-label">Menu</h2>
            <ul class="footer-line-content footer-links">
              <li><a href="/projets">Projets</a></li>
              <li><a href="/asso">L’association</a></li>
              <li><a href="/evenements">Événements</a></li>
              <li><a href="/adhesion">Rejoindre</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/veille">Actu</a></li>
              <li><a href="/flux">Flux RSS</a></li>
              <li><a href="/plan-du-site">Plan du site</a></li>
              <li><a href="/mentions-legales">Mentions légales</a></li>
            </ul>
          </div>
          <div class="footer-line">
            <h2 class="footer-line-label">Statut</h2>
            <ul class="footer-line-content footer-status">
              <li>
                <a
                  id="service-status-link"
                  class="service-status"
                  href="https://le-singe-du-numerique.betteruptime.com/"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-live="polite"
                >
                  <span id="service-status-dot" class="status-dot status-checking" aria-hidden="true"></span>
                  <span id="service-status-text">Statut : vérification...</span>
                </a>
              </li>
              <li><a href="/accessibilite">Accessibilité : non conforme</a></li>
              <li><a href="/contact">Aide : Contact</a></li>
              <li>Numéro d’association : W692012226</li>
            </ul>
          </div>
          <div class="footer-line">
            <h2 class="footer-line-label">Crédit</h2>
            <div class="footer-line-content">
              <span class="footer-credit">Fait avec ❤️ entre père et fils - Stan et Mikaël BOUCHET</span>
            </div>
          </div>
          <div class="footer-line">
            <h2 class="footer-line-label">Réseaux</h2>
            <ul class="footer-line-content footer-socials">
              <li>
                <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                  <span>LinkedIn Stan</span>
                </a>
              </li>
              <li>
                <a href="https://www.linkedin.com/in/mikael-bch/" target="_blank" rel="noopener noreferrer">
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
