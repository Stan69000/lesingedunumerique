    <button
      id="back-to-top"
      class="back-to-top"
      aria-label="Retour en haut de page"
      aria-hidden="true"
      tabindex="-1"
    >
      <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"></path></svg>
    </button>

    <script>
      const MIN_SAFE_ANIMATION_MS = 400;

      function parseAnimationTimeToMs(rawValue) {
        const value = (rawValue || '').trim();
        if (!value || value === '0' || value === '0s' || value === '0ms') return 0;
        if (value.endsWith('ms')) return Number.parseFloat(value);
        if (value.endsWith('s')) return Number.parseFloat(value) * 1000;
        return Number.parseFloat(value) || 0;
      }

      function toMsString(valueMs) {
        return `${Math.max(MIN_SAFE_ANIMATION_MS, Math.round(valueMs))}ms`;
      }

      function enforceMinimumAnimationDuration() {
        const allNodes = Array.from(document.querySelectorAll('*'));
        allNodes.forEach((node) => {
          const computed = window.getComputedStyle(node);
          if (computed.animationName === 'none') return;

          const durations = computed.animationDuration
            .split(',')
            .map((entry) => entry.trim())
            .filter(Boolean);

          if (durations.length === 0) return;

          const hasTooFastAnimation = durations.some(
            (duration) => parseAnimationTimeToMs(duration) > 0
              && parseAnimationTimeToMs(duration) < MIN_SAFE_ANIMATION_MS,
          );

          if (!hasTooFastAnimation) return;

          const clampedDurations = durations.map((duration) => {
            const valueMs = parseAnimationTimeToMs(duration);
            if (valueMs <= 0) return duration;
            return toMsString(valueMs);
          });

          node.style.animationDuration = clampedDurations.join(', ');
        });
      }

      window.addEventListener('load', enforceMinimumAnimationDuration);

      const themeBtn = document.getElementById('theme-toggle');
      const mobileThemeBtn = document.getElementById('mobile-theme-btn');
      const body = document.body;
      let lastFocusedElement = null;

      function syncThemeControls() {
        const isLight = body.classList.contains('light-mode');
        const icon = isLight ? '☀️' : '🌙';
        const actionLabel = isLight ? 'Activer le thème sombre' : 'Activer le thème clair';

        if (themeBtn) {
          themeBtn.innerHTML = isLight
            ? '<span class="icon-light">☀️</span>'
            : '<span class="icon-dark">🌙</span>';
          themeBtn.setAttribute('aria-label', actionLabel);
          themeBtn.setAttribute('aria-pressed', String(isLight));
        }

        if (mobileThemeBtn) {
          mobileThemeBtn.textContent = icon;
          mobileThemeBtn.setAttribute('aria-label', actionLabel);
          mobileThemeBtn.setAttribute('aria-pressed', String(isLight));
        }
      }

      if (localStorage.getItem('theme') === 'light') {
        body.classList.add('light-mode');
      }

      syncThemeControls();

      function toggleTheme() {
        body.classList.toggle('light-mode');
        const isLight = body.classList.contains('light-mode');
        syncThemeControls();
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
      }

      if (themeBtn) themeBtn.addEventListener('click', toggleTheme);
      if (mobileThemeBtn) mobileThemeBtn.addEventListener('click', toggleTheme);

      const burgerBtn = document.getElementById('burger-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      if (burgerBtn && mobileMenu) {
        const mobileFocusableSelector =
          'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

        const getMenuFocusableElements = () =>
          Array.from(mobileMenu.querySelectorAll(mobileFocusableSelector)).filter(
            (element) => !element.hasAttribute('hidden'),
          );

        const setMenuState = (isOpen) => {
          mobileMenu.classList.toggle('active', isOpen);
          burgerBtn.classList.toggle('active', isOpen);
          burgerBtn.setAttribute('aria-expanded', String(isOpen));
          burgerBtn.setAttribute(
            'aria-label',
            isOpen ? 'Fermer le menu principal' : 'Ouvrir le menu principal',
          );
          mobileMenu.hidden = !isOpen;
          mobileMenu.setAttribute('aria-hidden', String(!isOpen));
          if (isOpen) {
            mobileMenu.removeAttribute('inert');
          } else {
            mobileMenu.setAttribute('inert', '');
          }
          document.body.style.overflow = isOpen ? 'hidden' : '';

          const navRight = document.querySelector('.nav-right');
          const mainContent = document.getElementById('main-content');
          const footer = document.querySelector('.footer');

          [navRight, mainContent, footer].forEach((element) => {
            if (!element) return;
            if (isOpen) {
              element.setAttribute('inert', '');
            } else {
              element.removeAttribute('inert');
            }
          });

          if (isOpen) {
            lastFocusedElement = document.activeElement;
            window.setTimeout(() => {
              getMenuFocusableElements()[0]?.focus();
            }, 0);
          } else if (lastFocusedElement instanceof HTMLElement) {
            lastFocusedElement.focus();
            lastFocusedElement = null;
          }
        };

        setMenuState(false);

        burgerBtn.addEventListener('click', () => {
          const isOpen = burgerBtn.getAttribute('aria-expanded') !== 'true';
          setMenuState(isOpen);
        });

        document.querySelectorAll('.mobile-item').forEach((item) => {
          item.addEventListener('click', () => {
            setMenuState(false);
          });
        });

        document.addEventListener('keydown', (event) => {
          const menuIsOpen = burgerBtn.getAttribute('aria-expanded') === 'true';

          if (event.key === 'Escape' && menuIsOpen) {
            setMenuState(false);
            return;
          }

          if (event.key === 'Tab' && menuIsOpen) {
            const focusableElements = getMenuFocusableElements();
            if (focusableElements.length === 0) return;

            const firstElement = focusableElements[0];
            const lastElement = focusableElements[focusableElements.length - 1];
            const activeElement = document.activeElement;

            if (event.shiftKey && activeElement === firstElement) {
              event.preventDefault();
              lastElement.focus();
            } else if (!event.shiftKey && activeElement === lastElement) {
              event.preventDefault();
              firstElement.focus();
            }
          }
        });
      }

      const serviceStatusDot = document.getElementById('service-status-dot');
      const serviceStatusText = document.getElementById('service-status-text');

      function setServiceStatus(state) {
        if (!serviceStatusDot || !serviceStatusText) return;

        serviceStatusDot.classList.remove('status-checking', 'status-ok', 'status-ko', 'status-local');

        if (state === 'ok') {
          serviceStatusDot.classList.add('status-ok');
          serviceStatusText.textContent = 'Statut : opérationnel';
          return;
        }

        if (state === 'ko') {
          serviceStatusDot.classList.add('status-ko');
          serviceStatusText.textContent = 'Statut : incident détecté';
          return;
        }

        if (state === 'local') {
          serviceStatusDot.classList.add('status-local');
          serviceStatusText.textContent = 'Statut : vérif en production';
          return;
        }

        serviceStatusDot.classList.add('status-checking');
        serviceStatusText.textContent = 'Statut : vérification...';
      }

      async function refreshServiceStatus() {
        if (
          location.hostname === 'localhost'
          || location.hostname === '127.0.0.1'
          || location.hostname.endsWith('.local')
        ) {
          setServiceStatus('local');
          return;
        }

        setServiceStatus('checking');
        try {
          const response = await fetch('/contact-health.php', {
            method: 'GET',
            cache: 'no-store',
            credentials: 'same-origin',
          });
          const body = (await response.text()).trim();
          if (response.ok && body === 'OK') {
            setServiceStatus('ok');
            return;
          }
        } catch (error) {}
        setServiceStatus('ko');
      }

      if (serviceStatusDot && serviceStatusText) {
        refreshServiceStatus();
      }

      const homeSearchForm = document.querySelector('form.search-wrapper[role="search"]');
      const homeSearchInput = document.getElementById('home-search');
      const homeSearchError = document.getElementById('home-search-error');

      function clearHomeSearchError() {
        if (!homeSearchInput || !homeSearchError) return;
        homeSearchInput.removeAttribute('aria-invalid');
        homeSearchError.hidden = true;
        homeSearchError.textContent = '';
      }

      homeSearchInput?.addEventListener('input', clearHomeSearchError);

      homeSearchForm?.addEventListener('submit', (event) => {
        if (!homeSearchInput || !homeSearchError) return;
        const query = homeSearchInput.value.trim();

        if (query.length === 0) {
          clearHomeSearchError();
          return;
        }

        if (query.length < 2) {
          event.preventDefault();
          homeSearchInput.setAttribute('aria-invalid', 'true');
          homeSearchError.hidden = false;
          homeSearchError.textContent = 'Recherche trop courte. Essaie avec au moins 2 caractères.';
          homeSearchInput.focus();
          return;
        }

        clearHomeSearchError();
      });

      const backBtn = document.getElementById('back-to-top');
      const syncBackToTopVisibility = () => {
        if (!(backBtn instanceof HTMLButtonElement)) return;
        const shouldShow = window.scrollY > 400;
        backBtn.classList.toggle('visible', shouldShow);
        backBtn.setAttribute('aria-hidden', String(!shouldShow));
        backBtn.tabIndex = shouldShow ? 0 : -1;
      };

      syncBackToTopVisibility();
      window.addEventListener('scroll', () => {
        syncBackToTopVisibility();
      });
      backBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    </script>
        </>
      )
    }
