---
import MaintenanceContent from '../components/MaintenanceContent.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { siteSettings } from '../config/site';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  headline: string;
  accent?: string;
  intro?: string;
  showShare?: boolean;
  shareTitle?: string;
}

const {
  title,
  description = 'Le Singe Du Numerique',
  eyebrow,
  headline,
  accent = '',
  intro,
  showShare = true,
  shareTitle = accent ? `${headline} ${accent}` : headline,
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, siteSettings.siteUrl).toString();
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index,follow" />
    <meta property="og:site_name" content={siteSettings.siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteSettings.siteUrl}/logo.svg`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      siteSettings.maintenanceMode ? (
        <MaintenanceContent />
      ) : (
        <>
          <a class="skip-link" href="#main-content">Aller au contenu principal</a>

          <nav class="navbar" aria-label="Navigation principale">
            <div class="container nav-container">
              <a href="/" class="brand-logo">
                <img src="/logo.svg" alt="Le Singe Du Numérique" class="navbar-logo" />
                <span class="brand-text">Le Singe Du Numérique</span>
              </a>

              <div class="nav-right">
                <div class="nav-links">
                  <a href="/projets" class="nav-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
                  <a href="/asso" class="nav-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a>
                  <a href="/evenements" class="nav-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
                  <a href="/adhesion" class="nav-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a>
                  <a href="/contact" class="nav-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a>
                  <a href="/blog" class="nav-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
                </div>
                <button
                  id="theme-toggle"
                  class="theme-btn"
                  type="button"
                  aria-label="Activer le thème clair"
                  aria-pressed="false"
                >
                  <span class="icon-light">☀️</span>
                  <span class="icon-dark">🌙</span>
                </button>
              </div>

              <button
                class="burger-btn"
                id="burger-btn"
                aria-label="Ouvrir le menu principal"
                aria-controls="mobile-menu"
                aria-expanded="false"
              >
                <span></span>
                <span></span>
                <span></span>
              </button>
            </div>

            <div
              class="mobile-menu"
              id="mobile-menu"
              aria-label="Navigation mobile"
              aria-hidden="true"
              hidden
            >
              <a href="/projets" class="mobile-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
              <a href="/asso" class="mobile-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L’association</a>
              <a href="/evenements" class="mobile-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
              <a href="/adhesion" class="mobile-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Rejoindre</a>
              <a href="/contact" class="mobile-item" aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a>
              <a href="/blog" class="mobile-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
              <div class="mobile-theme-toggle">
                <span>Changer le thème</span>
                <button
                  id="mobile-theme-btn"
                  class="theme-btn-small"
                  type="button"
                  aria-label="Activer le thème clair"
                  aria-pressed="false"
                >
                  🌙
                </button>
              </div>
            </div>
          </nav>

          <main id="main-content">
            <section class="hero-section">
              <div class="glow-bg glow-green"></div>
              <div class="glow-bg glow-orange"></div>

              <div class="container hero-content">
                {eyebrow && <p class="eyebrow">{eyebrow}</p>}
                <h1 class="hero-title">
                  {headline} {accent && <span class="gradient-text">{accent}</span>}
                </h1>
                {intro && <p class="hero-desc">{intro}</p>}
              </div>
            </section>

            <section class="content-section">
              <div class="container page-body">
                <slot />
                {showShare && <ShareButtons title={shareTitle} />}
              </div>
            </section>
          </main>

          <footer class="footer">
            <div class="container footer-container">
              <div class="footer-main">
                <div class="footer-brand">
                  <img src="/logo.svg" alt="Le Singe Du Numérique" class="footer-logo" />
                  <span>Le Singe Du Numérique</span>
                </div>
                <div class="footer-line">
                  <span class="footer-line-label">Menu</span>
                  <div class="footer-line-content footer-links">
                    <a href="/projets">Projets</a>
                    <span class="footer-separator">•</span>
                    <a href="/asso">L’association</a>
                    <span class="footer-separator">•</span>
                    <a href="/evenements">Événements</a>
                    <span class="footer-separator">•</span>
                    <a href="/adhesion">Rejoindre</a>
                    <span class="footer-separator">•</span>
                    <a href="/contact">Contact</a>
                    <span class="footer-separator">•</span>
                    <a href="/blog">Blog</a>
                    <span class="footer-separator">•</span>
                    <a href="/mentions-legales">Mentions légales</a>
                  </div>
                </div>
                <div class="footer-line">
                  <span class="footer-line-label">Statut</span>
                  <div class="footer-line-content">
                    <a
                      id="service-status-link"
                      class="service-status"
                      href="https://le-singe-du-numerique.betteruptime.com/"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-live="polite"
                    >
                      <span id="service-status-dot" class="status-dot status-checking" aria-hidden="true"></span>
                      <span id="service-status-text">Statut : vérification...</span>
                    </a>
                    <span class="footer-separator">•</span>
                    <a href="/accessibilite">Accessibilité : non conforme</a>
                  </div>
                </div>
                <div class="footer-line">
                  <span class="footer-line-label">Crédit</span>
                  <div class="footer-line-content">
                    <span class="footer-credit">Fait avec ❤️ entre père et fils - Stan et Mikaël BOUCHET</span>
                  </div>
                </div>
                <div class="footer-line">
                  <span class="footer-line-label">Réseaux</span>
                  <div class="footer-line-content footer-socials">
                  <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                    <span>LinkedIn Stan</span>
                  </a>
                  <span class="footer-separator">•</span>
                  <a href="https://www.linkedin.com/in/mikael-bch/" target="_blank" rel="noopener noreferrer">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 7.06c1.08 0 1.75-.72 1.75-1.62-.02-.92-.67-1.62-1.73-1.62S3.5 4.52 3.5 5.44c0 .9.69 1.62 1.73 1.62h.02ZM20.5 20h-3.38v-6.15c0-1.54-.55-2.59-1.92-2.59-1.05 0-1.67.7-1.95 1.38-.1.24-.13.58-.13.92V20H9.74s.04-10.57 0-11.5h3.38v1.63c.45-.69 1.26-1.67 3.06-1.67 2.23 0 3.9 1.46 3.9 4.59V20Z"/></svg>
                    <span>LinkedIn Mikaël</span>
                  </a>
                  <span class="footer-separator">•</span>
                  <a href="https://github.com/Stan69000/lesingedunumerique" target="_blank" rel="noopener noreferrer">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.35-3.87-1.35-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.27 1.17-3.07-.12-.29-.5-1.47.11-3.05 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.13-1.17 3.13-1.17.62 1.58.24 2.76.12 3.05.73.8 1.17 1.82 1.17 3.07 0 4.41-2.69 5.37-5.25 5.66.41.36.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
                    <span>GitHub</span>
                  </a>
                </div>
              </div>
            </div>
          </footer>

          <script>
            const themeBtn = document.getElementById('theme-toggle');
            const mobileThemeBtn = document.getElementById('mobile-theme-btn');
            const body = document.body;
            let lastFocusedElement = null;

            function syncThemeControl() {
              const isLight = body.classList.contains('light-mode');
              const icon = isLight ? '☀️' : '🌙';
              const actionLabel = isLight ? 'Activer le thème sombre' : 'Activer le thème clair';

              if (themeBtn) {
                themeBtn.innerHTML = isLight
                  ? '<span class="icon-light">☀️</span>'
                  : '<span class="icon-dark">🌙</span>';
                themeBtn.setAttribute('aria-label', actionLabel);
                themeBtn.setAttribute('aria-pressed', String(isLight));
              }

              if (mobileThemeBtn) {
                mobileThemeBtn.textContent = icon;
                mobileThemeBtn.setAttribute('aria-label', actionLabel);
                mobileThemeBtn.setAttribute('aria-pressed', String(isLight));
              }
            }

            if (localStorage.getItem('theme') === 'light') {
              body.classList.add('light-mode');
            }

            syncThemeControl();

            function toggleTheme() {
              body.classList.toggle('light-mode');
              const isLight = body.classList.contains('light-mode');
              localStorage.setItem('theme', isLight ? 'light' : 'dark');
              syncThemeControl();
            }

            themeBtn?.addEventListener('click', toggleTheme);
            mobileThemeBtn?.addEventListener('click', toggleTheme);

            const burgerBtn = document.getElementById('burger-btn');
            const mobileMenu = document.getElementById('mobile-menu');

            if (burgerBtn && mobileMenu) {
              const mobileFocusableSelector =
                'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

              const getMenuFocusableElements = () =>
                Array.from(mobileMenu.querySelectorAll(mobileFocusableSelector)).filter(
                  (element) => !element.hasAttribute('hidden'),
                );

              const setMenuState = (isOpen) => {
                mobileMenu.classList.toggle('active', isOpen);
                burgerBtn.classList.toggle('active', isOpen);
                burgerBtn.setAttribute('aria-expanded', String(isOpen));
                burgerBtn.setAttribute(
                  'aria-label',
                  isOpen ? 'Fermer le menu principal' : 'Ouvrir le menu principal',
                );
                mobileMenu.hidden = !isOpen;
                mobileMenu.setAttribute('aria-hidden', String(!isOpen));
                document.body.style.overflow = isOpen ? 'hidden' : '';

                const navRight = document.querySelector('.nav-right');
                const mainContent = document.getElementById('main-content');
                const footer = document.querySelector('.footer');

                [navRight, mainContent, footer].forEach((element) => {
                  if (!element) return;
                  if (isOpen) {
                    element.setAttribute('inert', '');
                  } else {
                    element.removeAttribute('inert');
                  }
                });

                if (isOpen) {
                  lastFocusedElement = document.activeElement;
                  window.setTimeout(() => {
                    getMenuFocusableElements()[0]?.focus();
                  }, 0);
                } else if (lastFocusedElement instanceof HTMLElement) {
                  lastFocusedElement.focus();
                  lastFocusedElement = null;
                }
              };

              setMenuState(false);

              burgerBtn.addEventListener('click', () => {
                const isOpen = burgerBtn.getAttribute('aria-expanded') !== 'true';
                setMenuState(isOpen);
              });

              document.querySelectorAll('.mobile-item').forEach((item) => {
                item.addEventListener('click', () => {
                  setMenuState(false);
                });
              });

              document.addEventListener('keydown', (event) => {
                const menuIsOpen = burgerBtn.getAttribute('aria-expanded') === 'true';

                if (event.key === 'Escape' && menuIsOpen) {
                  setMenuState(false);
                  return;
                }

                if (event.key === 'Tab' && menuIsOpen) {
                  const focusableElements = getMenuFocusableElements();
                  if (focusableElements.length === 0) return;

                  const firstElement = focusableElements[0];
                  const lastElement = focusableElements[focusableElements.length - 1];
                  const activeElement = document.activeElement;

                  if (event.shiftKey && activeElement === firstElement) {
                    event.preventDefault();
                    lastElement.focus();
                  } else if (!event.shiftKey && activeElement === lastElement) {
                    event.preventDefault();
                    firstElement.focus();
                  }
                }
              });
            }

            const serviceStatusDot = document.getElementById('service-status-dot');
            const serviceStatusText = document.getElementById('service-status-text');

            function setServiceStatus(state) {
              if (!serviceStatusDot || !serviceStatusText) return;

              serviceStatusDot.classList.remove('status-checking', 'status-ok', 'status-ko', 'status-local');

              if (state === 'ok') {
                serviceStatusDot.classList.add('status-ok');
                serviceStatusText.textContent = 'Statut : opérationnel';
                return;
              }

              if (state === 'ko') {
                serviceStatusDot.classList.add('status-ko');
                serviceStatusText.textContent = 'Statut : incident détecté';
                return;
              }

              if (state === 'local') {
                serviceStatusDot.classList.add('status-local');
                serviceStatusText.textContent = 'Statut : vérif en production';
                return;
              }

              serviceStatusDot.classList.add('status-checking');
              serviceStatusText.textContent = 'Statut : vérification...';
            }

            async function refreshServiceStatus() {
              if (
                location.hostname === 'localhost'
                || location.hostname === '127.0.0.1'
                || location.hostname.endsWith('.local')
              ) {
                setServiceStatus('local');
                return;
              }

              setServiceStatus('checking');

              try {
                const response = await fetch('/contact-health.php', {
                  method: 'GET',
                  cache: 'no-store',
                  credentials: 'same-origin',
                });
                const body = (await response.text()).trim();
                if (response.ok && body === 'OK') {
                  setServiceStatus('ok');
                  return;
                }
              } catch (error) {}

              setServiceStatus('ko');
            }

            if (serviceStatusDot && serviceStatusText) {
              refreshServiceStatus();
              window.setInterval(refreshServiceStatus, 60000);
            }
          </script>
        </>
      )
    }
  </body>
</html>

<style>
  :root {
    --bg-body: #0b1120;
    --bg-card: #151e32;
    --text-main: #f1f5f9;
    --text-muted: #94a3b8;
    --brand-green: #2dd4bf;
    --brand-orange: #f97316;
    --brand-blue: #38bdf8;
    --border-color: rgba(255, 255, 255, 0.08);
    --glow-opacity: 0.15;
    --nav-height: 70px;
  }

  body.light-mode {
    --bg-body: #f8fafc;
    --bg-card: #ffffff;
    --text-main: #1e293b;
    --text-muted: #64748b;
    --brand-green: #0f766e;
    --brand-orange: #c2410c;
    --brand-blue: #0369a1;
    --border-color: rgba(0, 0, 0, 0.08);
    --glow-opacity: 0.08;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg-body);
    color: var(--text-main);
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.6;
    max-width: 100%;
    overflow-x: clip;
  }

  html {
    max-width: 100%;
    overflow-x: clip;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .skip-link {
    position: absolute;
    left: 16px;
    top: -48px;
    z-index: 200;
    padding: 10px 14px;
    border-radius: 12px;
    background: #ffffff;
    color: #07131d;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .skip-link:focus {
    top: 16px;
  }

  .container {
    width: min(100%, 1100px);
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .navbar {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 16px 0;
    background: rgba(11, 17, 32, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  body.light-mode .navbar {
    background: rgba(248, 250, 252, 0.85);
  }

  .nav-container,
  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .brand-logo,
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
  }

  .footer-main {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
  }

  .footer-line {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 12px;
    align-items: start;
  }

  .footer-line-label {
    font-size: 0.86rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .footer-line-content {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .navbar-logo,
  .footer-logo {
    height: 40px;
    width: auto;
    display: block;
  }

  .brand-text {
    display: none;
  }

  .nav-links,
  .footer-links {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-item,
  .footer-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .nav-item[aria-current='page'] {
    color: var(--text-main);
  }

  .nav-item:hover,
  .footer-links a:hover {
    color: var(--brand-green);
  }

  .footer-credit {
    color: var(--text-muted);
    font-size: 0.95rem;
    text-align: left;
  }

  .footer-socials {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 12px;
  }

  .footer-socials a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .footer-socials svg {
    width: 16px;
    height: 16px;
    flex: 0 0 16px;
  }

  .footer-socials a:hover {
    color: var(--brand-green);
  }

  .service-status {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .service-status:hover {
    color: var(--text-main);
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    display: inline-block;
    background: #94a3b8;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15);
  }

  .status-dot.status-checking {
    background: var(--brand-orange);
  }

  .status-dot.status-ok {
    background: #22c55e;
  }

  .status-dot.status-ko {
    background: #ef4444;
  }

  .status-dot.status-local {
    background: var(--brand-blue);
  }

  .theme-btn {
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    color: var(--text-main);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
  }

  .theme-btn:hover {
    border-color: var(--brand-green);
    background: rgba(128, 128, 128, 0.1);
  }

  .icon-dark { display: block; }
  .icon-light { display: none; }

  body.light-mode .icon-dark { display: none; }
  body.light-mode .icon-light { display: block; }

  .burger-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 21;
    flex-direction: column;
    gap: 5px;
    padding: 5px;
  }

  .burger-btn span {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--text-main);
    transition: 0.3s;
  }

  .mobile-menu {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    width: 100%;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-color);
    padding: 20px;
    display: flex;
    flex-direction: column;
