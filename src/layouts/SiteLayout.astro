---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  headline: string;
  accent?: string;
  intro?: string;
}

const {
  title,
  description = 'Le Singe Du Numerique',
  eyebrow,
  headline,
  accent = '',
  intro,
} = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@300;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>

    <nav class="navbar" aria-label="Navigation principale">
      <div class="container nav-container">
        <a href="/" class="brand-logo">
          <img src="/logo.svg" alt="Le Singe Du Numérique" class="navbar-logo" />
          <span class="brand-text">Le Singe Du Numérique</span>
        </a>

        <div class="nav-links">
          <a href="/projets" class="nav-item" aria-current={currentPath === '/projets' ? 'page' : undefined}>Projets</a>
          <a href="/asso" class="nav-item" aria-current={currentPath === '/asso' ? 'page' : undefined}>L'Asso</a>
          <a href="/evenements" class="nav-item" aria-current={currentPath === '/evenements' ? 'page' : undefined}>Événements</a>
          <a href="/adhesion" class="nav-item" aria-current={currentPath === '/adhesion' ? 'page' : undefined}>Adhérer</a>
          <a href="/blog" class="nav-item" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <section class="hero-section">
        <div class="glow-bg glow-green"></div>
        <div class="glow-bg glow-orange"></div>

        <div class="container hero-content">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          <h1 class="hero-title">
            {headline} {accent && <span class="gradient-text">{accent}</span>}
          </h1>
          {intro && <p class="hero-desc">{intro}</p>}
        </div>
      </section>

      <section class="content-section">
        <div class="container page-body">
          <slot />
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-container">
        <div class="footer-brand">
          <img src="/logo.svg" alt="Le Singe Du Numérique" class="footer-logo" />
          <span>Le Singe Du Numérique</span>
        </div>
        <div class="footer-links">
          <a href="/projets">Projets</a>
          <span class="footer-separator">•</span>
          <a href="/evenements">Événements</a>
          <span class="footer-separator">•</span>
          <a href="/adhesion">Adhérer</a>
          <span class="footer-separator">•</span>
          <a href="/mentions-legales">Mentions légales</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg-body: #0b1120;
    --bg-card: #151e32;
    --text-main: #f1f5f9;
    --text-muted: #94a3b8;
    --brand-green: #2dd4bf;
    --brand-orange: #f97316;
    --brand-blue: #38bdf8;
    --border-color: rgba(255, 255, 255, 0.08);
    --glow-opacity: 0.15;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg-body);
    color: var(--text-main);
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .skip-link {
    position: absolute;
    left: 16px;
    top: -48px;
    z-index: 200;
    padding: 10px 14px;
    border-radius: 12px;
    background: #ffffff;
    color: #07131d;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .skip-link:focus {
    top: 16px;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .navbar {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 16px 0;
    background: rgba(11, 17, 32, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  .nav-container,
  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .brand-logo,
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
  }

  .navbar-logo,
  .footer-logo {
    height: 40px;
    width: auto;
    display: block;
  }

  .brand-text {
    display: none;
  }

  .nav-links,
  .footer-links {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .nav-item,
  .footer-links a {
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }

  .nav-item[aria-current='page'] {
    color: var(--text-main);
  }

  .nav-item:hover,
  .footer-links a:hover {
    color: var(--brand-green);
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible,
  [tabindex]:focus-visible {
    outline: 3px solid var(--brand-green);
    outline-offset: 3px;
  }

  .nav-item:focus-visible,
  .footer-links a:focus-visible,
  .brand-logo:focus-visible {
    border-radius: 12px;
  }

  .hero-section {
    position: relative;
    overflow: hidden;
    padding: 4rem 0 2rem;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .glow-bg {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: var(--glow-opacity);
  }

  .glow-green {
    top: -100px;
    left: -100px;
    width: 340px;
    height: 340px;
    background: var(--brand-green);
  }

  .glow-orange {
    top: 20px;
    right: -140px;
    width: 420px;
    height: 420px;
    background: var(--brand-orange);
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--brand-green);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0 0 1rem;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--brand-green), var(--brand-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    max-width: 620px;
    margin: 0;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .content-section {
    padding: 1rem 0 4rem;
  }

  .page-body {
    display: grid;
    gap: 24px;
  }

  .footer {
    border-top: 1px solid var(--border-color);
    padding: 28px 0 40px;
  }

  .footer-separator {
    color: var(--text-muted);
  }

  :global(.info-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  :global(.info-card) {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 22px;
    padding: 24px;
  }

  :global(.info-card h2),
  :global(.info-card h3) {
    margin: 0 0 0.8rem;
    font-size: 1.35rem;
  }

  :global(.info-card p),
  :global(.info-card li),
  :global(.prose-block p),
  :global(.prose-block li) {
    color: var(--text-muted);
  }

  :global(.prose-block) {
    background: rgba(21, 30, 50, 0.65);
    border: 1px solid var(--border-color);
    border-radius: 22px;
    padding: 28px;
  }

  :global(.cta-row) {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  :global(.cta-button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--brand-green), var(--brand-blue));
    color: #061018;
    font-weight: 700;
  }

  :global(.cta-secondary) {
    border: 1px solid var(--border-color);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-main);
  }

  @media (min-width: 768px) {
    .brand-text {
      display: inline;
    }
  }

  @media (max-width: 760px) {
    .nav-container,
    .footer-container {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
