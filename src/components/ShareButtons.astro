---
interface Props {
  title: string;
  label?: string;
  shareMessage?: string;
}

const {
  title,
  label = 'Partager cette page',
  shareMessage = `À lire sur Le Singe Du Numérique : ${title}`,
} = Astro.props;
const headingId = `share-title-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'page'}`;
---

<section
  class="social-share"
  data-share-widget
  data-share-title={title}
  data-share-message={shareMessage}
  aria-labelledby={headingId}
>
  <h2 id={headingId} class="social-share-title">{label}</h2>
  <ul class="social-share-links">
    <li>
      <button type="button" data-share-platform="facebook">
        Partager sur Facebook
      </button>
    </li>
    <li>
      <button type="button" data-share-platform="x">
        Partager sur X
      </button>
    </li>
    <li>
      <button type="button" data-share-platform="linkedin">
        Partager sur LinkedIn
      </button>
    </li>
    <li>
      <button type="button" data-share-platform="whatsapp">
        Partager sur WhatsApp
      </button>
    </li>
    <li>
      <button type="button" data-share-copy>Copier le lien</button>
    </li>
  </ul>
  <p class="social-share-feedback" aria-live="polite"></p>
</section>

<script is:inline>
  document.querySelectorAll('[data-share-widget]').forEach((widget) => {
    const title = widget.getAttribute('data-share-title') || document.title;
    const message = widget.getAttribute('data-share-message') || title;
    const url = window.location.href;
    const encodedUrl = encodeURIComponent(url);
    const encodedMessage = encodeURIComponent(message);

    const urls = {
      facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}&quote=${encodedMessage}`,
      x: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedMessage}`,
      linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
      whatsapp: `https://wa.me/?text=${encodeURIComponent(`${message} ${url}`)}`,
    };

    widget.querySelectorAll('[data-share-platform]').forEach((button) => {
      const platform = button.getAttribute('data-share-platform');
      if (platform && urls[platform]) {
        button.addEventListener('click', () => {
          window.open(urls[platform], '_blank', 'noopener,noreferrer');
        });
      }
    });

    const feedback = widget.querySelector('.social-share-feedback');
    const copyButton = widget.querySelector('[data-share-copy]');
    copyButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        if (feedback) feedback.textContent = 'Lien copié.';
      } catch {
        if (feedback) feedback.textContent = 'Impossible de copier le lien.';
      }
    });
  });
</script>

<style>
  .social-share {
    margin-top: 12px;
    padding: 22px;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(21, 30, 50, 0.65);
    color: var(--text-main);
  }

  .social-share-title {
    margin: 0 0 14px;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .social-share-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.95rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .social-share-links button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-main);
    text-decoration: none;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .social-share-links button:hover {
    border-color: rgba(94, 234, 212, 0.65);
    color: #99f6e4;
  }

  .social-share-feedback {
    min-height: 1.2em;
    margin: 12px 0 0;
    color: #94a3b8;
    font-size: 0.9rem;
  }

  :global(body.light-mode) .social-share {
    background: rgba(255, 255, 255, 0.88);
    border-color: rgba(0, 0, 0, 0.08);
  }

  :global(body.light-mode) .social-share-links button {
    background: rgba(15, 23, 42, 0.06);
    border-color: rgba(15, 23, 42, 0.18);
    color: #1e293b;
  }

  :global(body.light-mode) .social-share-links button:hover {
    border-color: rgba(15, 118, 110, 0.5);
    color: #0f766e;
  }

  :global(body.light-mode) .social-share-feedback {
    color: #64748b;
  }
</style>
