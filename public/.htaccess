ErrorDocument 404 /404.html

RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; frame-src 'self' https://www.openstreetmap.org; upgrade-insecure-requests"
</IfModule>

# Configuration du formulaire de contact pour O2Switch/PHP.
# Décommente puis adapte ces deux lignes avant mise en production.
# SetEnv CONTACT_RECIPIENT_EMAIL "contact@votre-domaine.fr"
# SetEnv CONTACT_FROM_EMAIL "no-reply@votre-domaine.fr"

# Pour un mode maintenance côté Apache sur O2Switch, décommente les lignes ci-dessous.
# RewriteEngine On
# RewriteCond %{REQUEST_URI} !^/maintenance\.html$
# RewriteCond %{REQUEST_URI} !^/contact\.php$
# RewriteCond %{REQUEST_URI} !^/favicon\.ico$
# RewriteCond %{REQUEST_URI} !^/favicon\.svg$
# RewriteRule ^.*$ /maintenance.html [R=302,L]
