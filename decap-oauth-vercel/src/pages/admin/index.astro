---
const isLocal = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin | Le Singe Du Numérique</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      :root {
        color-scheme: dark;
      }

      body {
        margin: 0;
        font-family: "Space Grotesk", sans-serif;
        background: #000;
        color: #e5e7eb;
      }

      .admin-loading {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px 20px;
        background:
          radial-gradient(circle at top left, rgba(45, 212, 191, 0.12), transparent 32%),
          radial-gradient(circle at bottom right, rgba(56, 189, 248, 0.1), transparent 32%),
          #000;
      }

      .admin-loading-card {
        width: min(680px, 100%);
        padding: 32px 28px;
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, 0.35);
        background: rgba(15, 23, 42, 0.86);
        backdrop-filter: blur(14px);
      }

      .admin-loading-card h1 {
        margin: 0 0 12px;
        font-size: clamp(2rem, 5vw, 3rem);
        line-height: 1.05;
      }

      .admin-loading-card p {
        margin: 0;
        color: #cbd5e1;
        line-height: 1.7;
      }

      body.admin-theme-dark,
      body.admin-theme-dark #nc-root {
        background: #000 !important;
        color: #e5e7eb !important;
      }

      body.admin-theme-dark #nc-root * {
        border-color: rgba(148, 163, 184, 0.35) !important;
      }

      body.admin-theme-dark #nc-root p,
      body.admin-theme-dark #nc-root span,
      body.admin-theme-dark #nc-root label,
      body.admin-theme-dark #nc-root li,
      body.admin-theme-dark #nc-root h1,
      body.admin-theme-dark #nc-root h2,
      body.admin-theme-dark #nc-root h3,
      body.admin-theme-dark #nc-root h4,
      body.admin-theme-dark #nc-root h5,
      body.admin-theme-dark #nc-root h6 {
        color: #e5e7eb !important;
      }

      body.admin-theme-dark #nc-root a {
        color: #7dd3fc !important;
      }

      body.admin-theme-dark #nc-root input,
      body.admin-theme-dark #nc-root textarea,
      body.admin-theme-dark #nc-root select,
      body.admin-theme-dark #nc-root [contenteditable='true'] {
        background: #0f172a !important;
        color: #f8fafc !important;
      }

      body.admin-theme-dark #nc-root button {
        color: #f8fafc !important;
      }
    </style>
  </head>
  <body>
    <main class="admin-loading" id="admin-loading">
      <section class="admin-loading-card">
        <h1>Administration du contenu</h1>
        <p>
          Chargement de l’interface d’édition du blog.
        </p>
      </section>
    </main>

    <script src="https://unpkg.com/decap-cms@^3.3.3/dist/decap-cms.js"></script>
    <script define:vars={{ isLocal }}>
      const loading = document.getElementById('admin-loading');

      window.CMS.init({
        local_backend: isLocal,
        backend: {
          name: 'github',
          repo: 'Stan69000/lesingedunumerique',
          branch: 'main',
          site_domain: 'lesingedunumerique.fr',
          base_url: window.location.origin,
          auth_endpoint: 'oauth',
        },
        site_url: 'https://lesingedunumerique.fr',
        display_url: 'https://lesingedunumerique.fr',
        logo_url: '/logo.svg',
        media_folder: 'public/blog',
        public_folder: '/blog',
        slug: {
          encoding: 'ascii',
          clean_accents: true,
        },
        collections: [
          {
            name: 'blog',
            label: 'Blog',
            label_singular: 'Article',
            folder: 'src/content/blog',
            create: true,
            delete: true,
            extension: 'md',
            format: 'frontmatter',
            slug: '{{slug}}',
            summary: '{{title}} — {{rubrique}}',
            editor: {
              preview: false,
            },
            fields: [
              { label: 'Titre', name: 'title', widget: 'string' },
              { label: 'Description', name: 'description', widget: 'text' },
              {
                label: 'Date de publication',
                name: 'pubDate',
                widget: 'datetime',
                format: 'YYYY-MM-DD',
                date_format: 'YYYY-MM-DD',
                time_format: false,
              },
              {
                label: 'Rubrique',
                name: 'rubrique',
                widget: 'select',
                options: ['Articles', 'Veille', 'Technos'],
              },
              {
                label: 'Tags',
                name: 'tags',
                widget: 'list',
                allow_add: true,
                collapsed: false,
                hint: 'Exemples : Débutant, Cybersécurité, Seniors, Libre',
              },
              {
                label: 'Auteur',
                name: 'author',
                widget: 'string',
                required: false,
                hint: 'Nom affiché sur l’article. Exemple : Stan Bouchet',
              },
              { label: 'Contenu', name: 'body', widget: 'markdown' },
            ],
          },
        ],
      });

      const applyDarkTheme = () => {
        const cmsRoot = document.getElementById('nc-root');
        if (cmsRoot) {
          document.body.classList.add('admin-theme-dark');
          if (loading) loading.style.display = 'none';
          observer.disconnect();
        }
      };

      const observer = new MutationObserver(applyDarkTheme);
      observer.observe(document.body, { childList: true, subtree: true });
      window.addEventListener('load', applyDarkTheme);
    </script>
  </body>
</html>
